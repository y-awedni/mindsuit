# === Dependencies (reinstalled via composer) ===
/vendor/
/composer.phar

# === Secrets & environment ===
# .env is committed with safe dev defaults; real secrets go in .env.local.
/.env.local
/.env.*.local
/docker/.env
*.pem

# === Database dumps (never commit customer data) ===
/docker/mysql/init/*
!/docker/mysql/init/.gitkeep
*.sql
*.sql.gz
*.dump

# === Symfony runtime (cache, logs, sessions) ===
/var/*
!/var/cache/
/var/cache/*
!/var/cache/.gitkeep
!/var/log/
/var/log/*
!/var/log/.gitkeep
!/var/sessions/
/var/sessions/*
!/var/sessions/.gitkeep

# === User uploads ===
/public/uploads/*
!/public/uploads/.gitkeep

# === Binaries managed by composer ===
/bin/*
!/bin/console

# === Build / test artifacts ===
/build/
/phpunit.xml
/.phpunit.result.cache
.phpstan-baseline.neon.tmp

# === Host / IDE / OS junk ===
/.idea/
/.vscode/
/.cursor/
*.db
.DS_Store
Thumbs.db
error_log
*.log

# === Doctrine generated backups ===
**/Entity/*~
