{
    "name": "lead_dev/mind-manager",
    "license": "proprietary",
    "type": "project",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=7.2.5",
        "symfony/symfony": "^5.4",
        "doctrine/orm": "^2.5",
        "doctrine/persistence": "^2.5",
        "doctrine/doctrine-bundle": "^2.0",
        "symfony/monolog-bundle": "^3.5",
        "symfony/polyfill-apcu": "^1.0",
        "sensio/framework-extra-bundle": "^6.1",
        "twig/twig": "^2.13",
        "knplabs/knp-paginator-bundle": "^5.0",
        "knplabs/knp-time-bundle": "^1.16",
        "phpoffice/phpspreadsheet": "^1.6",
        "pear/numbers_words": "^0.18.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.5",
        "symfony/phpunit-bridge": "^5.4"
    },
    "config": {
        "sort-packages": true
    }
}
