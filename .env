# Committed defaults for local/dev. Real secrets go in .env.local (gitignored)
# or the server environment. See docs/DEPLOYMENT.md.
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=dev_only_secret_change_in_prod_0a1b2c3d4e5f6071

# MySQL 5.7 dev container (see docker-compose.yml).
# NOTE: this points at the CONTROL database (tenants/plans/subscriptions).
# Per-tenant ERP databases are switched into at runtime by TenantConnection.
DATABASE_URL="mysql://mindsuit:mindsuit@database:3306/mindsuit?serverVersion=5.7"

# Multi-tenancy. Apex = control plane; <sub>.<APP_BASE_DOMAIN> = tenant.
APP_BASE_DOMAIN=moudir.pro
# When set, requests without a subdomain (bare host) resolve to this tenant.
# Empty in production (apex must stay the control plane); set in dev/test.
DEFAULT_TENANT=
