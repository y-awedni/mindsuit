{% trans_default_domain 'FOSUserBundle' %}

<div class="container-fluid container-fluid-fixed-top">
    <section class="content-header">
        <nav class="navbar navbar-default">
            <div class="container-fluid">
                <ul class="nav navbar-nav navbar-left">
                    <li><a href="{{path('fos_user_profile_show')}}"><span class="glyphicon glyphicon-eye-open"></span> Afficher</a></li>
                </ul>
            </div>
        </nav> 
    </section>
    <!-- /.row -->
    <div class="row">
        <div class="col-lg-12">
            <div class="panel panel-default">
                <div class="panel-heading">
                    {{ 'change_password.submit'|trans }}
                </div>
                <!-- /.panel-heading -->
                <div class="panel-body">
                    {{ form_start(form, { 'action': path('fos_user_change_password'), 'attr': { 'class': 'fos_user_change_password' } }) }}
                    {% form_theme form 'bootstrap_3_layout.html.twig' %}
                    {{ form_widget(form) }}
                    <div>
                        <input class="btn btn-success" type="submit" value="{{ 'change_password.submit'|trans }}" />
                    </div>
                    {{ form_end(form) }}

                </div>
            </div>
        </div>
    </div>
</div>
