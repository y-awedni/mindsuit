{% extends 'base.html.twig' %}

{% block title %}{{ parent()~' - Vente de client par document ' }}{% endblock %}
{% block body %}
    {% set currentPath = path(app.request.attributes.get('_route'),app.request.attributes.get('_route_params')) %}
    {% set currentPath=currentPath~'?a=b' %}
    {% if app.request.get('limit') is not null %}
        {% set currentPath=currentPath~'&limit='~app.request.get('limit') %}
    {% endif %}
    {% if app.request.get('sort') is not null %}
        {% set currentPath=currentPath~'&sort='~app.request.get('sort') %}
    {% endif %}
    {% if app.request.get('direction') is not null %}
        {% set currentPath=currentPath~'&direction='~app.request.get('direction') %}
    {% endif %}
    {% set currentPath=currentPath~'&code='~app.request.get('code') %}
    {% set currentPath=currentPath~'&designation='~app.request.get('designation') %}
    <div class="container-fluid container-fluid-fixed-top">
        {% include 'fiche/client/menu.html.twig' with { 'client':client } %}
        <!-- /.row -->
        <div class="row">
            <div class="col-lg-12">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        <div class="count">
                            {{ nombreVentes }} articles vendus par client <a href="{{ path('client_show',{'id':client.id} ) }}">{{ client }}</a>
                        </div> 
                    </div>
                    <!-- /.panel-heading -->
                    <div class="panel-body">
                        <div class="panel panel-default">
                            <div class="panel-heading">
                                <h4 class="panel-title">
                                    <a data-toggle="collapse" data-parent="#accordion" href="#collapseOne"><span class="glyphicon glyphicon-chevron-down"></span> Filtrage</a>
                                </h4>
                            </div>
                            <div id="collapseOne" class="panel-collapse collapse">
                                <div class="panel-body">
                                    <form method="GET">
                                        <div class="row">
                                            <div class="col-sm-6 ">
                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <div class="form-group">
                                                            <label for="code">Référence article</label>
                                                            <input class="form-control" name="code" id="code" value="{{ app.request.get('code')}}">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="form-group">
                                                            <label for="designation">Désignation article</label>
                                                            <input class="form-control" name="designation" id="designation" value="{{ app.request.get('designation')}}">
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-6">
                                                <div class="form-group">
                                                    <label for="limit">Nombre d'éléments par page </label>
                                                    <select name='limit' class="form-control selectpicker" data-live-search="true">
                                                        <option {% if app.request.get('limit')=='10' %}selected{% endif %} value="10">10 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='25' %}selected{% endif %} value="25">25 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='50' %}selected{% endif %} value="50">50 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='100' %}selected{% endif %} value="100">100 éléments par page</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                        <button type="submit" class="btn btn-info"><span class="glyphicon glyphicon-filter"></span> Filtrer</button>
                                        <a href="{{path('fiche_client_vente_article',{'id':client.id} )}}" class="btn btn-default"><span class="glyphicon glyphicon-filter"></span> Reinitialiser</a>
                                    </form>
                                </div>
                            </div>
                        </div>
                        <table width="100%" class="table table-striped table-bordered table-hover">
                            <thead>
                                <tr>
                                    {% set direction='ASC' %}
                                    {% if app.request.get('direction') is not null %}
                                        {% set direction=app.request.get('direction')=='DESC'?'ASC':'DESC' %}
                                    {% endif %}
                                    <th><a href="{{ currentPath~"&sort=art.code&direction="~direction }}">Réference article</a></th>
                                    <th><a href="{{ currentPath~"&sort=art.designation&direction="~direction }}">Désignation article</a></th>
                                    <th><a href="{{ currentPath~"&sort=qte&direction="~direction }}">Quantité vendus</a></th>
                                    <th><a href="{{ currentPath~"&sort=ttc&direction="~direction }}">Total TTC</a></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for vente in pagination %}
                                    <tr>
                                        <td>{{ vente.code }}</td>
                                        <td>{{ vente.designation }}</td>
                                        <td>{{ vente.qte }}</td>
                                        <td>{{ vente.ttc }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        {% if countCurrentPage >0 %}
                            <ul class="pagination">
                                <li class="prev {% if currentPage==1 %}disabled{% endif %}" {% if currentPage>1 %}style="cursor:pointer"{% endif %}>
                                    <a {% if currentPage>1 %} href="{{ currentPath }}&offset={{currentPage-2}}" {% endif %} title="{% if currentPage!=1 %}page {{currentPage-1}}{% endif %}" >
                                        « Précédent
                                    </a>
                                </li>
                                {% for i in 1..currentPage %}
                                    {% if i!=currentPage %}
                                        <li>
                                            <a href="{{ currentPath }}&offset={{i-1}}">
                                                {{ i }}
                                            </a>
                                        </li>
                                    {% endif %}
                                {% endfor %}
                                <li class="active">
                                    <a>{{ currentPage }}</a>
                                </li>
                                {% for i in currentPage..lastPage %}
                                    {% if i!=currentPage%}
                                        <li>
                                            <a href="{{ currentPath }}&offset={{i-1}}">
                                                {{ i }}
                                            </a>
                                        </li>
                                    {% endif %}
                                {% endfor %}
                                <li class="next {% if currentPage==lastPage %}disabled{% endif %}" {% if currentPage<lastPage %}style="cursor:pointer"{% endif %}>
                                    <a {% if currentPage<lastPage %} href="{{ currentPath }}&offset={{currentPage}}" {% endif %} title="{% if currentPage!=lastPage %}page {{currentPage+1}}{% endif %}">
                                        Suivant »
                                    </a>
                                </li>
                            </ul>
                        {% endif %}    
                    </div>
                    <div class="panel-footer">
                        <a href="{{ path('fiche_client_vente_article_xls',{
                                'code':app.request.get('code'),
                                'client':client.id,
                                'designation':app.request.get('designation') } )}}" class="btn btn-default">
                            <span class="glyphicon glyphicon-download-alt"></span> Exporter en Excel
                        </a>
                    </div>
                </div>
                <!-- totaux -->
                {{ render(controller(
                    'AppBundle:TotauxFicheClient:totauxParArticle',
                    {
                        'code':app.request.get('code'),
                        'typeDoc':app.request.get('designation'),
                        'client':client.id
                    }
                )) }}            
            </div>
        </div>
    </div>
{% endblock %}
{% block javascripts %}
    <script type="text/javascript">
        var myVar = setInterval(myTimer, 2000);
        function myTimer() {
            var x = document.readyState;
            if (x === 'complete') {
                document.getElementById('loader').style.display = 'none';
                $('.container-fluid').removeAttr("style");
            }
        }
    </script>
{% endblock %}