{% extends 'base.html.twig' %}
{% block title %}{{ parent()~' - Factures' }}{% endblock %}
{% block body %}
    <div class="container-fluid container-fluid-fixed-top">
        <section class="content-header">
            <nav class="navbar navbar-default">
                <div class="container-fluid">
                    <ul class="nav navbar-nav navbar-left">
                        <li><a href="{{path('facture_new')}}"><span class="glyphicon glyphicon-plus"></span> Ajouter</a></li>
                    </ul>
                </div>
            </nav> 
        </section>
        <!-- /.row -->
        <div class="row">
            <div class="col-lg-12">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        <div class="count">
                            {{ pagination.getTotalItemCount }} Factures
                        </div> 
                    </div>
                    <!-- /.panel-heading -->
                    <div class="panel-body">
                        <div class="panel panel-default">
                            <div class="panel-heading">
                                <h4 class="panel-title">
                                    <a data-toggle="collapse" data-parent="#accordion" href="#collapseOne"><span class="glyphicon glyphicon-chevron-down"></span> Filtrage</a>
                                </h4>
                            </div>
                            <div id="collapseOne" class="panel-collapse collapse">
                                <div class="panel-body">
                                    <form role="form" action="{{path('facture_index')}}" method="GET">
                                        <div class="row">
                                            <div class="col-sm-6 ">
                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <div class="form-group">
                                                            <label for="code">Code</label>
                                                            <input class="form-control" name="code" id="code" value="{{ app.request.get('code')}}">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="form-group">
                                                            <label for="client">Client</label>
                                                            <select name='client' class="form-control selectpicker" data-live-search="true">
                                                                <option value=""></option>
                                                                {% for client in clients %}
                                                                    <option {% if app.request.get('client')==client.id %}selected{% endif %} value="{{ client.id }}">
                                                                        {{ client }}
                                                                    </option>
                                                                {% endfor %}
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <div class="form-group">
                                                            <label for="dateCreation">Date de création</label>
                                                            <div class="input-daterange input-group" id="datepicker">
                                                             
                                                                
                                                                <input type="text" class="form-control" value="{{ app.request.get('startDateCreation')}}" name="startDateCreation" />
                                                                <span class="input-group-addon">vers</span>
                                                                <input type="text" class="form-control" value="{{ app.request.get('endDateCreation')}}" name="endDateCreation" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="form-group">
                                                            <label for="dateEcheance">Date d'écheance</label>
                                                            <div class="input-daterange input-group" id="datepicker">
                                                                <input type="text" class="form-control" value="{{ app.request.get('startDateEcheance')}}" name="startDateEcheance" />
                                                                <span class="input-group-addon">vers</span>
                                                                <input type="text" class="form-control" value="{{ app.request.get('endDateEcheance')}}" name="endDateEcheance" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-6">
                                                <div class="form-group">
                                                    <label for="limit">Nombre d'éléments par page </label>
                                                    <select name='limit' class="form-control selectpicker" data-live-search="true">
                                                        <option {% if app.request.get('limit')=='10' %}selected{% endif %} value="10">10 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='25' %}selected{% endif %} value="25">25 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='50' %}selected{% endif %} value="50">50 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='100' %}selected{% endif %} value="100">100 éléments par page</option>
                                                    </select>
                                                </div>
                                                <div class="form-group">
                                                    <div class="row">
                                                        <div class="col-md-6">
                                                            <div class="form-group">
                                                                <div class="radio">
                                                                    <label>
                                                                        <input {{app.request.get('termine')==2?'checked':''}} type="radio" name="termine" value="2">
                                                                        <em class="label label-success">
                                                                            Terminé
                                                                        </em>
                                                                    </label>
                                                                </div>
                                                                <div class="radio">
                                                                    <label>
                                                                        <input {{app.request.get('termine')==1?'checked':''}} type="radio" name="termine" value="1">
                                                                        <em class="label label-warning">
                                                                            En cours
                                                                        </em>
                                                                    </label>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <div class="form-group">
                                                                <div class="radio">
                                                                    <label>
                                                                        <input {{app.request.get('regle')==1?'checked':''}} type="radio" name="regle" value="1">
                                                                        <em class="label label-success">
                                                                            Reglé
                                                                        </em>
                                                                    </label>
                                                                </div>
                                                                <div class="radio">
                                                                    <label>
                                                                        <input {{app.request.get('regle')==2?'checked':''}} type="radio" name="regle" value="2">
                                                                        <em class="label label-warning">
                                                                            En cours
                                                                        </em>
                                                                    </label>
                                                                </div>
                                                                <div class="radio">
                                                                    <label>
                                                                        <input {{app.request.get('regle')==3?'checked':''}} type="radio" name="regle" value="3">
                                                                        <em class="label label-danger">
                                                                            Non Reglé
                                                                        </em>
                                                                    </label>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <button type="submit" class="btn btn-info"><span class="glyphicon glyphicon-filter"></span> Filtrer</button>
                                        <a href="{{path('facture_index')}}" class="btn btn-default"><span class="glyphicon glyphicon-filter"></span> Reinitialiser</a>
                                    </form>
                                </div>
                            </div>
                        </div>
                        <table width="100%" class="table table-striped table-bordered table-hover">
                            <thead>
                                <tr>
                                    <th>{{ knp_pagination_sortable(pagination, 'Code', 'a.code') }}</th>
                                    <th>{{ knp_pagination_sortable(pagination, 'Client', 'clt.code') }}</th>
                                    <th {% if pagination.isSorted('a.termine') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, 'Etat', 'a.termine') }}</th>
                                    <th>Réglé</th>
                                    <th {% if pagination.isSorted('a.total') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, 'Total', 'a.total') }}</th>
                                    <th {% if pagination.isSorted('a.regle') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, 'Déja réglé', 'a.regle') }}</th>
                                    <th {% if pagination.isSorted('a.reste') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, 'Reste', 'a.reste') }}</th>
                                    <th {% if pagination.isSorted('a.dateCreation') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, 'Date de création', 'a.dateCreation') }}</th>
                                    <th {% if pagination.isSorted('a.dateEcheance') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, "Date d'échéance", 'a.dateEcheance') }}</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for facture in pagination %}
                                    <tr>
                                        <td>{{ facture.code }}</td>
                                        <td><a href="{{ path('client_show',{'id':facture.client.id}) }}">{{ facture.client }}</a></td>
                                        <td>
                                            <em class="label label-{{ facture.termine?'success':'warning' }}">
                                                {{ facture.termine?'Terminé':'En cours' }}
                                            </em>
                                        </td>
                                        <td>
                                            {% if facture.regle==0 %}
                                                {% set labelColor='danger' %}
                                                {% set regleText='Non reglé' %}
                                            {% elseif facture.regle==facture.total %}
                                                {% set labelColor='success' %}
                                                {% set regleText='Reglé' %}
                                            {% elseif facture.regle<facture.total %}
                                                {% set labelColor='warning' %}
                                                {% set regleText='en cours' %}
                                            {% endif %}
                                            <em class="label label-{{ labelColor }}">
                                                {{ regleText }}
                                            </em>
                                        </td>
                                        <td>{{ facture.total|number_format('3','.',' ') }}</td>
                                        <td>{{ facture.regle|number_format('3','.',' ') }}</td>
                                        <td class="center">
                                               {# facture.reste>=0?(facture.total- facture.regle)|number_format(3, '.', ' '):'0.000' #}
                                               {{ facture.reste>=0?(facture.reste)|number_format(3, '.', ' '):'0.000' }}
                                              
                                        </td>
                                        <td>{{ facture.dateCreation|date("d/m/Y") }}</td>
                                        <td>{{ facture.dateEcheance|date("d/m/Y") }}</td>
                                        <td>
                                            <a class="btn btn-success btn-xs" href="{{ path('facture_show', { 'id': facture.id }) }}">
                                                <span class="glyphicon glyphicon-eye-open"></span> Afficher
                                            </a>
                                            <a title="Pour modifier cette facture il faut la terminer" {{ facture.termine?"disabled onclick='return false'":"" }} class="btn btn-primary btn-xs" href="{{ path('facture_edit', { 'id': facture.id }) }}">
                                                <span class="glyphicon glyphicon-edit"></span> Modifier
                                            </a>
                                            <a title="Pour régler cette facture il faut la terminer" {{ facture.termine!=true?"disabled onclick='return false'":"" }} class="btn btn-warning btn-xs" href="{{ path('facture_reglements', { 'id': facture.id }) }}">
                                                <span class="fa fa-money"></span> Réglements
                                            </a>
                                            <button title="Pour faire un avoir cette facture il faut la régler" {{ facture.total!=facture.regle?"disabled onclick='return false'":"" }} class="btn btn-info btn-xs" data-toggle="modal" data-target="#myModal{{facture.id}}">
                                                <span class="fa fa-reply-all"></span> Avoirs
                                            </button>
                                            <!-- Modal -->
                                            <div class="modal fade" id="myModal{{facture.id}}" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
                                                <div class="modal-dialog">
                                                    <div class="modal-content">
                                                        <div class="modal-header">
                                                            <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                                                            <h4 class="modal-title" id="myModalLabel">{{ facture }}</h4>
                                                        </div>
                                                        <div class="modal-body">
                                                            <a class="btn btn-info" href="{{ path('factureavoir_facture', { 'id': facture.id }) }}">
                                                                <span class="fa fa-reply-all"></span> Liste des factures avoirs
                                                            </a>
                                                            <a class="btn btn-success" href="{{ path('factureavoir_facture_new', { 'id': facture.id }) }}">
                                                                <span class="fa fa-plus-square"></span> Ajouter facture avoir
                                                            </a>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-default" data-dismiss="modal">Fermer</button>
                                                        </div>
                                                    </div>
                                                    <!-- /.modal-content -->
                                                </div>
                                                <!-- /.modal-dialog -->
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        <div class="navigation">
                            {{ knp_pagination_render(pagination) }}
                        </div>
                    </div>
                    <div class="panel-footer">
                        <a class="btn btn-success" href="{{ path('factureglobal',{
                                'code':app.request.get('code'),
                                'termine':app.request.get('termine'),
                                'regle':app.request.get('regle'),
                                'client':app.request.get('client'),
                                'startDateCreation':app.request.get('startDateCreation'),
                                'endDateCreation':app.request.get('endDateCreation'),
                                'startDateEcheance':app.request.get('startDateEcheance'),
                                'endDateEcheance':app.request.get('endDateEcheance') } )}}" class="btn btn-default">
                            <span class="glyphicon glyphicon-print"></span> Imprimer
                        </a>
                        <a href="{{ path('facture_export_xls',{
                                'code':app.request.get('code'),
                                'termine':app.request.get('termine'),
                                'regle':app.request.get('regle'),
                                'client':app.request.get('client'),
                                'startDateCreation':app.request.get('startDateCreation'),
                                'endDateCreation':app.request.get('endDateCreation'),
                                'startDateEcheance':app.request.get('startDateEcheance'),
                                'endDateEcheance':app.request.get('endDateEcheance') } )}}" class="btn btn-default">
                            <span class="glyphicon glyphicon-download-alt"></span> Exporter en Excel
                        </a>
                    </div>
                </div>
                <!-- totaux -->
                {{ render(controller(
                    'AppBundle:Facture:totauxFacture',
                    {
                        'code':app.request.get('code'),
                        'termine':app.request.get('termine'),
                        'regle':app.request.get('regle'),
                        'client':app.request.get('client'),
                        'startDateCreation':app.request.get('startDateCreation'),
                        'endDateCreation':app.request.get('endDateCreation'),
                        'startDateEcheance':app.request.get('startDateEcheance'),
                        'endDateEcheance':app.request.get('endDateEcheance')
                    }
                )) }}
            </div>
        </div>
    </div>
{% endblock %}
{% block javascripts %}
    <script type="text/javascript">
        var myVar = setInterval(myTimer, 2000);
        function myTimer() {
            var x = document.readyState;
            if (x === 'complete') {
                document.getElementById('loader').style.display = 'none';
                $('.container-fluid').removeAttr("style");
            }
        }
        /*
         * Nous sommes dans le scope global,
         * aussi l'objet `keys` est accessible partout
         * dans le code à travers tous les fichiers JavaScript.
         */
        var keys = {};
        /*
         * Étant dans le code global,
         * `window.onkeydown` est identique à `this.onkeydown` 
         * lui même identique à `onkeydown`.
         * On associe ci-dessous la même fonction lorsqu'une
         * touche est appuyée, et lorsqu'une touche est relachée.
         */
        onkeydown = onkeyup = function (e) {
            /*
             * Si `e` n'existe pas, 
             * nous somme probablement dans un vieux IE.
             * On affecte alors `event` à `e`.
             */
            e = e || event;
            /*
             * Si la fonction courante est executée, 
             * quand une touche est enfoncée,
             * `e.type === 'keydown'` renverra `true`
             * sinon elle renverra `false`.
             * Il suffit alors d'assigner chaque état 
             * dans le tableau `keys` pour chaque
             * touche `e.keyCode`.
             */
            keys[e.keyCode] = e.type === 'keydown';
            /*
             * Cette zone sera exécutée lorsque les touches
             * Ctrl (17) et b (66)
             * seront enfoncée en même temps
             * car l'objet `keys` vaudra alors :
             * {
             *  17: true,
             *  18: true,
             *  69: true
             * }
             */
            if (keys[17] && keys[66]) {
                window.location.href = "{{ path('facture_benifice_index') }}";
            }
        }
    </script>
{% endblock %}
