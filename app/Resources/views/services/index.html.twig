{% extends 'base.html.twig' %}

{% block title %}{{ parent()~' - Services vendus ' }}{% endblock %}
{% block body %}
    <div class="container-fluid container-fluid-fixed-top">
        <section class="content-header">
            <nav class="navbar navbar-default">
                <div class="container-fluid">
                    <ul class="nav navbar-nav navbar-left">

                    </ul>
                </div>
            </nav> 
        </section>
        <!-- /.row -->
        <div class="row">
            <div class="col-lg-12">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        <div class="count">
                            {{ pagination.getTotalItemCount }} Mouvements
                        </div> 
                    </div>
                    <!-- /.panel-heading -->
                    <div class="panel-body">
                        <div class="panel panel-default">
                            <div class="panel-heading">
                                <h4 class="panel-title">
                                    <a data-toggle="collapse" data-parent="#accordion" href="#collapseOne"><span class="glyphicon glyphicon-chevron-down"></span> Filtrage</a>
                                </h4>
                            </div>
                            <div id="collapseOne" class="panel-collapse collapse">
                                <div class="panel-body">
                                    <form role="form" action="{{path('services_index')}}" method="GET">
                                        <div class="row">
                                            <div class="col-sm-6 ">
                                                <div class="form-group row">
                                                    <div class="col-sm-6">
                                                        <label for="designation">Désignation</label>
                                                        <input class="form-control" name="designation" id="designation" value="{{ app.request.get('designation')}}">
                                                    </div>
                                                    <div class="col-sm-3">
                                                        <label for="type">Type article</label>
                                                        <select name='type' class="form-control selectpicker" data-live-search="true" id="type">
                                                            <option {% if app.request.get('type')=='tous' %}selected{% endif %} value="tous">Tous</option>
                                                            <option {% if app.request.get('type')=='services' %}selected{% endif %} value="services">Services</option>
                                                            <option {% if app.request.get('type')=='produitNonStockable' %}selected{% endif %} value="produitNonStockable">Produits non stockable</option>
                                                        </select>
                                                    </div>
                                                    <div class="col-sm-3">
                                                        <label for="article">Article</label>
                                                        <select name='article' class="form-control selectpicker" data-live-search="true" title="tous">
                                                            <option value="">tous</option>
                                                            {% for article in articles %}
                                                                <option {% if app.request.get('article')==article.id %}selected{% endif %} value="{{ article.id }}">{{ article.code }}</option>
                                                            {% endfor %}
                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="form-group row">
                                                    <div class="col-sm-6">
                                                        <label for="mouvement">Mouvement (E/S)</label>
                                                        <select name='mouvement' class="form-control selectpicker" data-live-search="true" id="mouvement" onchange="changeMouvement(this)">
                                                            <option {% if app.request.get('mouvement')=='tous' %}selected{% endif %} value="tous">Tous</option>
                                                            <option {% if app.request.get('mouvement')=='entre' %}selected{% endif %} value="entre">Entré</option>
                                                            <option {% if app.request.get('mouvement')=='sortie' %}selected{% endif %} value="sortie">Sortie</option>
                                                        </select>
                                                    </div>
                                                    <div class="col-sm-6" id="fournisseurs">
                                                        <label for="fournisseur">Fournisseur</label>
                                                        <select name='fournisseur' class="form-control selectpicker" data-live-search="true" title="tous">
                                                            <option value="">tous</option>
                                                            {% for fournisseur in fournisseurs %}
                                                                <option {% if app.request.get('fournisseur')==fournisseur.id %}selected{% endif %} value="{{ fournisseur.id }}">{{ fournisseur }}</option>
                                                            {% endfor %}
                                                        </select>
                                                    </div>
                                                    <div class="col-sm-6" id="clients">
                                                        <label for="client">Client</label>
                                                        <select name='client' class="form-control selectpicker" data-live-search="true" title="tous">
                                                            <option value="">tous</option>
                                                            {% for client in clients %}
                                                                <option {% if app.request.get('client')==client.id %}selected{% endif %} value="{{ client.id }}">{{ client }}</option>
                                                            {% endfor %}
                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="form-group">
                                                    <label for="date">Date</label>
                                                    <div class="input-daterange input-group" id="datepicker">
                                                        <input type="text" class="form-control" value="{{ app.request.get('startDateCreation')}}" name="startDateCreation" />
                                                        <span class="input-group-addon">vers</span>
                                                        <input type="text" class="form-control" value="{{ app.request.get('endDateCreation')}}" name="endDateCreation" />
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-6">
                                                <div class="form-group">
                                                    <label for="limit">Nombre d'éléments par page </label>
                                                    <select name='limit' class="form-control selectpicker" data-live-search="true">
                                                        <option {% if app.request.get('limit')=='10' %}selected{% endif %} value="10">10 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='25' %}selected{% endif %} value="25">25 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='50' %}selected{% endif %} value="50">50 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='100' %}selected{% endif %} value="100">100 éléments par page</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                        <button type="submit" class="btn btn-info"><span class="glyphicon glyphicon-filter"></span> Filtrer</button>
                                        <a href="{{path('services_index')}}" class="btn btn-default"><span class="glyphicon glyphicon-filter"></span> Reinitialiser</a>
                                    </form>
                                </div>
                            </div>
                        </div>
                        <table width="100%" class="table table-striped table-bordered table-hover">
                            <thead>
                                <tr>
                                    <th>{{ knp_pagination_sortable(pagination, 'Désignation', 'a.designation') }}</th>
                                    <th style="width: 125px;">{{ knp_pagination_sortable(pagination, 'Article', 'art.code') }}</th>
                                    <th style="width: 125px;">{{ knp_pagination_sortable(pagination, 'Qte', 'a.qte') }}</th>
                                    <th style="width: 125px;">{{ knp_pagination_sortable(pagination, 'Mouvement', 'a.mouvement') }}</th>
                                    <th>Tier</th>
                                    <th style="width: 125px;">{{ knp_pagination_sortable(pagination, 'Montant total', 'a.ttc') }}</th>
                                    <th style="width: 160px;">{{ knp_pagination_sortable(pagination, 'Date', 'a.createdAt') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for stock in pagination %}
                                    <tr {{ stock.mouvement? "class='success'":"class='danger'" }}>
                                        <td>{{ stock.designation }}</td>
                                        <td><a href="{{ path('article_show',{'id':stock.article.id} ) }}">{{ stock.article }}</a></td>
                                        <td>{{ stock.qte }}</td>
                                        <td>
                                            {{ stock.mouvement? 'Entré':'Sortie' }}
                                        </td>
                                        <td>
                                            {% set pathTier='' %}
                                            {% if stock.fournisseur %}
                                                {% set pathTier=path('fournisseur_show',{'id':stock.fournisseur.id} ) %}
                                            {% elseif stock.client %}
                                                {% set pathTier=path('client_show',{'id':stock.client.id} ) %}
                                            {% endif %}
                                            <a href="{{ pathTier }}">
                                                {{ stock.tier }}
                                            </a>
                                        </td>
                                        <td>{{ stock.ttc }}</td>
                                        <td>{{ stock.dateCreation?stock.dateCreation|date('d-m-Y'):'' }}
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        <div class="navigation">
                            {{ knp_pagination_render(pagination) }}
                        </div>
                    </div>
                    <div class="panel-footer">
                        <a href="{{ path('service_export_xls',{
                                'designation':app.request.get('designation'),
                                'article':app.request.get('article'),
                                'mouvement':app.request.get('mouvement'),
                                'fournisseur':app.request.get('fournisseur'),
                                'client':app.request.get('client'),
                                'startDateCreation':app.request.get('startDateCreation'),
                                'endDateCreation':app.request.get('endDateCreation') } )}}" class="btn btn-default">
                            <span class="glyphicon glyphicon-download-alt"></span> Exporter en Excel
                        </a>
                    </div>    
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <script type="text/javascript">
        var myVar = setInterval(myTimer, 2000);
        function myTimer() {
            var x = document.readyState;
            if (x === 'complete') {
                document.getElementById('loader').style.display = 'none';
                $('.container-fluid').removeAttr("style");
            }
        }
        function changeMvt(mvtValue) {
            switch (mvtValue) {
                case 'tous':
                    document.getElementById('clients').style.display = 'none';
                    document.getElementById('fournisseurs').style.display = 'none';
                    break;
                case 'entre':
                    document.getElementById('clients').style.display = 'none';
                    document.getElementById('fournisseurs').removeAttribute('style');
                    break;
                case 'sortie':
                    document.getElementById('fournisseurs').style.display = 'none';
                    document.getElementById('clients').removeAttribute('style');
                    break;
            }
        }
        changeMvt(document.getElementById('mouvement').value);

        function changeMouvement(mvt) {
            changeMvt(mvt.value);
        }
    </script>
{% endblock %}
