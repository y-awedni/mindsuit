


{% extends 'base.html.twig' %}
{% block title %}{{ parent()~' - Ajout stock manuelle ' }}{% endblock %}

{% block body %}
    <div class="container-fluid container-fluid-fixed-top">
        <section class="content-header">
            <nav class="navbar navbar-default">
                <div class="container-fluid">
                    <ul class="nav navbar-nav navbar-left">
                        <li><a href="{{path('stock_index')}}"><span class="glyphicon glyphicon-transfer"></span> Liste des mouvements de stock</a></li>
                    </ul>
                </div>
            </nav> 
        </section>
        <!-- /.row -->
        <div class="row">
            <div class="col-lg-12">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        Ajout stock manuelle
                    </div>
                    <!-- /.panel-heading -->
                    <div class="panel-body">
                        {% form_theme form 'bootstrap_3_layout.html.twig' %}
                        {{ form_start(form) }}
                        <div class="row">
                            <div class="col-lg-6">
                                {% form_theme form 'bootstrap_3_layout.html.twig' %}
                                {{ form_row(form.article) }}
                                {{ form_row(form.note) }}
                            </div>
                            <div class="col-lg-6">
                                {% form_theme form 'bootstrap_3_layout.html.twig' %}
                                {{ form_row(form.qte) }}
                                {{ form_row(form.dateCreation) }}
                            </div>
                        </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}