{% extends 'base.html.twig' %}
{% block title %}{{ parent()~' - Bons de réceptions' }}{% endblock %}

{% block body %}
    <div class="container-fluid container-fluid-fixed-top">
        <section class="content-header">
            <nav class="navbar navbar-default">
                <div class="container-fluid">
                    <ul class="nav navbar-nav navbar-left">
                        <li><a href="{{path('bonreception_new')}}"><span class="glyphicon glyphicon-plus"></span> Ajouter</a></li>
                        <li>
                            <a style="cursor: pointer" data-toggle="modal" data-target="#myModal">
                                <span class="glyphicon glyphicon-plus"></span> Ajouter à partir du bon de commande
                            </a>
                            <!-- Modal -->
                            <div class="modal fade" id="myModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                                            <h4 class="modal-title" id="myModalLabel">Ajouter bon de réception à partir du bon de commande</h4>
                                        </div>
                                        <div class="modal-body">
                                            <form role="form" action="{{path('bonreception_boncommande_new_id')}}" method="GET">
                                                <div class="form-group row">
                                                    <div class="col-sm-6" id="factures">
                                                        <label for="boncommande">Sélectionner bon de commande</label>
                                                        <select name='id' class="form-control selectpicker" data-live-search="true" title="tous">
                                                            {% for boncommande in boncommandes %}
                                                                <option value="{{ boncommande.id }}">{{ boncommande.code }}</option>
                                                            {% endfor %}
                                                        </select>
                                                    </div>
                                                </div>
                                                <button type="submit" class="btn btn-info"><span class="fa fa-plus-square"></span> Ajouter</button>    
                                            </form>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-default" data-dismiss="modal">Fermer</button>
                                        </div>
                                    </div>
                                    <!-- /.modal-content -->
                                </div>
                                <!-- /.modal-dialog -->
                            </div>
                        </li>
                    </ul>
                </div>
            </nav> 
        </section>
        <!-- /.row -->
        <div class="row">
            <div class="col-lg-12">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        <div class="count">
                            {{ pagination.getTotalItemCount }} Bon du réception
                        </div> 
                    </div>
                    <!-- /.panel-heading -->
                    <div class="panel-body">
                        <div class="panel panel-default">
                            <div class="panel-heading">
                                <h4 class="panel-title">
                                    <a data-toggle="collapse" data-parent="#accordion" href="#collapseOne"><span class="glyphicon glyphicon-chevron-down"></span> Filtrage</a>
                                </h4>
                            </div>
                            <div id="collapseOne" class="panel-collapse collapse">
                                <div class="panel-body">
                                    <form role="form" action="{{path('bonreception_index')}}" method="GET">
                                        <div class="row">
                                            <div class="col-sm-6">
                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <div class="form-group">
                                                            <label for="code">Code</label>
                                                            <input class="form-control" name="code" id="code" value="{{ app.request.get('code')}}">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="form-group">
                                                            <label for="fournisseur">Fournisseur</label>
                                                            <select name='fournisseur' class="form-control selectpicker" data-live-search="true">
                                                                <option value=""></option>
                                                                {% for fournisseur in fournisseurs %}
                                                                    <option {% if app.request.get('fournisseur')==fournisseur.id %}selected{% endif %} value="{{ fournisseur.id }}">
                                                                        {{ fournisseur }}
                                                                    </option>
                                                                {% endfor %}
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <div class="form-group">
                                                            <label for="dateCreation">Date de création</label>
                                                            <div class="input-daterange input-group" id="datepicker">
                                                                <input type="text" class="form-control" value="{{ app.request.get('startDateCreation')}}" name="startDateCreation" />
                                                                <span class="input-group-addon">vers</span>
                                                                <input type="text" class="form-control" value="{{ app.request.get('endDateCreation')}}" name="endDateCreation" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="form-group">
                                                            <label for="dateCommande">Date de réception</label>
                                                            <div class="input-daterange input-group" id="datepicker">
                                                                <input type="text" class="form-control" value="{{ app.request.get('startDateReception')}}" name="startDateReception" />
                                                                <span class="input-group-addon">vers</span>
                                                                <input type="text" class="form-control" value="{{ app.request.get('endDateReception')}}" name="endDateReception" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-sm-6">
                                                <div class="form-group">
                                                    <label for="limit">Nombre d'éléments par page </label>
                                                    <select name='limit' class="form-control selectpicker" data-live-search="true">
                                                        <option {% if app.request.get('limit')=='10' %}selected{% endif %} value="10">10 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='25' %}selected{% endif %} value="25">25 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='50' %}selected{% endif %} value="50">50 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='100' %}selected{% endif %} value="100">100 éléments par page</option>
                                                    </select>
                                                </div>
                                                
                                                <div class="form-group">
                                                    <div class="row">
                                                        <div class="col-md-6">
                                                            <div class="form-group">
                                                                <div class="radio">
                                                                    <label>
                                                                        <input {{app.request.get('termine')==2?'checked':''}} type="radio" name="termine" value="2">
                                                                        <em class="label label-success">
                                                                            Terminé
                                                                        </em>
                                                                    </label>
                                                                </div>
                                                                <div class="radio">
                                                                    <label>
                                                                        <input {{app.request.get('termine')==1?'checked':''}} type="radio" name="termine" value="1">
                                                                        <em class="label label-warning">
                                                                            En cours
                                                                        </em>
                                                                    </label>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <div class="form-group">
                                                                <div class="radio">
                                                                    <label>
                                                                        <input {{app.request.get('regle')==1?'checked':''}} type="radio" name="regle" value="1">
                                                                        <em class="label label-success">
                                                                            Reglé
                                                                        </em>
                                                                    </label>
                                                                </div>
                                                                <div class="radio">
                                                                    <label>
                                                                        <input {{app.request.get('regle')==2?'checked':''}} type="radio" name="regle" value="2">
                                                                        <em class="label label-warning">
                                                                            En cours
                                                                        </em>
                                                                    </label>
                                                                </div>
                                                                <div class="radio">
                                                                    <label>
                                                                        <input {{app.request.get('regle')==3?'checked':''}} type="radio" name="regle" value="3">
                                                                        <em class="label label-danger">
                                                                            Non Reglé
                                                                        </em>
                                                                    </label>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>    
                                            </div>

                                        </div>
                                        <button type="submit" class="btn btn-info"><span class="glyphicon glyphicon-filter"></span> Filtrer</button>
                                        <a href="{{path('bonreception_index')}}" class="btn btn-default"><span class="glyphicon glyphicon-filter"></span> Reinitialiser</a>
                                    </form>

                                </div>
                            </div>
                        </div>
                        <table width="100%" class="table table-striped table-bordered table-hover">
                            <thead>
                                <tr>
                                    <th>{{ knp_pagination_sortable(pagination, 'Code', 'a.code') }}</th>
                                    <th>{{ knp_pagination_sortable(pagination, 'Fournisseur', 'frs.code') }}</th>
                                    <th {% if pagination.isSorted('a.termine') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, 'Etat', 'a.termine') }}</th>
                                    <th>Réglé</th>
                                    <th {% if pagination.isSorted('a.total') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, 'Total', 'a.total') }}</th>
                                    <th {% if pagination.isSorted('a.regle') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, 'Déja réglé', 'a.regle') }}</th>
                                    <th {% if pagination.isSorted('a.createdAt') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, 'Date de création', 'a.createdAt') }}</th>
                                    <th {% if pagination.isSorted('a.dateReception') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, "Date de réception", 'a.dateReception') }}</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for bonreception in pagination %}
                                    <tr>
                                        <td>{{ bonreception.code }}</td>
                                        <td><a href="{{ path('fournisseur_show',{'id':bonreception.fournisseur.id } ) }}">{{ bonreception.fournisseur }}</a></td>
                                        <td>
                                            <em class="label label-{{ bonreception.termine?'success':'warning' }}">
                                                {{ bonreception.termine?'Terminé':'En cours' }}
                                            </em>
                                        </td>
                                        <td>
                                            {% if bonreception.regle==0 %}
                                                {% set labelColor='danger' %}
                                                {% set regleText='Non reglé' %}
                                            {% elseif bonreception.regle==bonreception.total %}
                                                {% set labelColor='success' %}
                                                {% set regleText='Reglé' %}
                                            {% elseif bonreception.regle<bonreception.total %}
                                                {% set labelColor='warning' %}
                                                {% set regleText='en cours' %}
                                            {% endif %}
                                            <em class="label label-{{ labelColor }}">
                                                {{ regleText }}
                                            </em>
                                        </td>
                                        <td>{{ bonreception.total|number_format('3','.',' ') }}</td>
                                        <td>{{ bonreception.regle|number_format('3','.',' ') }}</td>
                                        <td>{{ bonreception.createdAt|date("d/m/Y") }}</td>
                                        <td>{{ bonreception.dateReception|date("d/m/Y") }}</td>
                                        <td>
                                            <a class="btn btn-success btn-xs" href="{{ path('bonreception_show', { 'id': bonreception.id }) }}">
                                                <span class="glyphicon glyphicon-eye-open"></span> Afficher
                                            </a>
                                            <a title="Pour modifier ce bon de réception il faut le terminer" {{ bonreception.termine?"disabled onclick='return false'":"" }} class="btn btn-primary btn-xs" href="{{ path('bonreception_edit', { 'id': bonreception.id }) }}">
                                                <span class="glyphicon glyphicon-edit"></span> Modifier
                                            </a>
                                            <a title="Pour régler ce bon de réception il faut le terminer" {{ bonreception.termine!=true?"disabled onclick='return false'":"" }} class="btn btn-warning btn-xs" href="{{ path('bonreception_reglements', { 'id': bonreception.id }) }}">
                                                <span class="fa fa-money"></span> Réglements
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        <div class="navigation">
                            {{ knp_pagination_render(pagination) }}
                        </div>
                    </div>
                    <div class="panel-footer">
                        <a href="{{ path('bonreception_export_xls',{
                            'code':app.request.get('code'),
                            'fournisseur':app.request.get('fournisseur'),
                            'termine':app.request.get('termine'),
                            'regle':app.request.get('regle'),
                            'startDateReception':app.request.get('startDateReception'),
                            'endDateReception':app.request.get('endDateReception'),
                            'startDateCreation':app.request.get('startDateCreation'),
                            'endDateCreation':app.request.get('endDateCreation') } )}}" class="btn btn-default">
                            <span class="glyphicon glyphicon-download-alt"></span> Exporter en Excel
                        </a>
                    </div>
                </div>
                <!-- totaux -->
                {{ render(controller(
                    'AppBundle:BonReception:totauxBr',
                    {
                        'code':app.request.get('code'),
                        'fournisseur':app.request.get('fournisseur'),
                        'termine':app.request.get('termine'),
                        'regle':app.request.get('regle'),
                        'startDateCreation':app.request.get('startDateCreation'),
                        'endDateCreation':app.request.get('endDateCreation'),
                        'startDateReception':app.request.get('startDateReception'),
                        'endDateReception':app.request.get('endDateReception')
                    }
                )) }}
            </div>
        </div>
    </div>
{% endblock %}
{% block javascripts %}
    <script type="text/javascript">
        var myVar = setInterval(myTimer, 2000);
        function myTimer() {
            var x = document.readyState;
            if (x === 'complete') {
                document.getElementById('loader').style.display = 'none';
                $('.container-fluid').removeAttr("style");
            }
        }
    </script>
{% endblock %}