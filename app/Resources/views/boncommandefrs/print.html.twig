<html>
    <head>
        <title>{{ bonCommandeFrs.code }}</title>
        <style>
            .print-box {
                font-size: 8px;
                line-height: 18px;
                font-family: 'Helvetica Neue', 'Helvetica', Helvetica, Arial, sans-serif;
                color: #555;
            }
            .print-box table tr.information table td{
                font-size: 14px;
            }
            .print-box table {
                width: 100%;
                line-height: inherit;
                text-align: left;
            }
            .print-box table td {
                padding: 3px;
                vertical-align: top;
            }
            .print-box table tr td:nth-child(2) {
                text-align: right;
            }
            .print-box table tr.top table td {
                padding-bottom: 20px;

            }

            .print-box table tr.top table td.title {
                font-size: 45px;
                line-height: 45px;
                color: #333;
            }
            .print-box table tr.top table td.code {
                width: 70%;
                text-align: left;
            }
            .print-box table tr.information table td {
                padding-bottom: 40px;
            }
            .print-box table tr.information table td.societe {
                width: 50%;
            }
            .print-box table tr.information table td.client {
                width: 30%;
                text-align: left;
            }
            .print-box table tr.heading td {
                background: #13b3d9;
                border-bottom: 1px solid #ddd;
                font-weight: bold;
                font-size: 12px;
            }
            .print-box table tr.details td {
                padding-bottom: 20px;
            }
            .print-box table tr.item td {
                border-bottom: 1px solid #eee;
                font-size: 12px;
            }
            .print-box table tr.item:nth-child(odd) {background: #eee;}
            .print-box table tr.item:nth-child(even) {background: #fff;}

            .print-box table tr.item.last td {
                border-bottom: none;
            }
            .print-box table tr.total td:nth-child(2) {
                border-top: 2px solid #eee;
                font-weight: bold;
            }
            .center{
                text-align:center;
            }
            .left{
                text-align: left!important;
            }
            .right{
                text-align: right!important;
            }
            .print-box table tr.bottom td table{
                padding-top: 10px;
                font-size: 14px;
            }
            div.totaux{
                width: 30%;
                position: absolute;
                top: 0;
                right: 0;
            }
            div.totaux table{
                border: 1px solid #ddd;
                border-collapse: collapse;
                width: 100%;
            }
            div.totaux table th{
                background: #eee;
                width: 50%;
            }
            div.baseTva{
                width: 25%;
                position: absolute;
                top: 0;
                right: 240px;
            }

            div.baseTva table.tableauTVA{
                width: 100%;
                float: right;
                border: 1px solid #ddd;
                border-collapse: collapse;
            }
            div.baseTva table.tableauTVA td{
                font-size: 16px!important;
            }

            .font16{
                font-size: 16px!important;
            }

            div.baseTva table thead{
                background: #13b3d9;
                border-bottom: 1px solid #ddd;
                font-weight: bold;
                font-size: 12px;
            }
            div.baseTva table tbody tr:nth-child(odd) {background: #eee;}
            div.baseTva table tbody tr:nth-child(even) {background: #fff;}

            @media only screen and (max-width: 600px) {
                .print-box table tr.top table td {
                    width: 100%;
                    display: block;
                    text-align: center;
                }
                .print-box table tr.information table td {
                    width: 100%;
                    display: block;
                    text-align: center;
                }
            }

            body.relative {
                position: relative;
            }
            div.absolute {
                position: absolute;
                bottom: 0px;
                right: 4px;
                width: 98%;
                height: 180px;
                font-size:12px;
            }
        </style>
    </head>
    <body class="relative" onload="window.print()">
        <div id="print" >
            <div class="print-box">
                <table cellpadding="0" cellspacing="0" >
                    <tr class="top">
                        <td colspan="3">
                            <table>
                                <tr>
                                    <td class="title">
                                        {% if societe.desactiverPhoto==false and societe.media %}
                                            <img style="width:75px; max-width:200px;" src="{{ asset(societe.media.assetPath) }}">
                                        {% endif %}
                                    </td>

                                    <td class="code" style="text-align: center">
                                        <h3><strong>Bon de commande fournisseur </strong>: {{ bonCommandeFrs.code }}</h3>
                                    </td>
                                    <td class="date" style="text-align: right">
                                        Date : {{ bonCommandeFrs.dateCreation|date("d/m/Y")}}
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr class="information">
                        <td colspan="3">
                            <table>
                                <tr>
                                    <td class="societe">
                                        {% if societe.adresse %}
                                            {{societe.adresse}}<br>
                                            {{societe.codePostale~' '~societe.ville~' '~societe.pays}}<br>
                                        {% endif %}

                                        {% if societe.tel %}
                                            <b>Tél-Fax : </b>{{societe.tel}}<br>
                                        {% endif %}
                                        {% if societe.mobile %}
                                            <b>Mobile : </b>{{ societe.mobile }}<br>
                                        {% endif %}
                                        {% if societe.email %}
                                            <b>Email : </b>{{ societe.email }}<br>
                                        {% endif %}
                                        {% if societe.mf %}
                                            <b>M.F : </b>{{ societe.mf }}<br>
                                        {% endif %}
                                        {% if societe.rcs %}
                                            <b>R.Cs : </b>{{ societe.rcs }}<br>
                                        {% endif %}
                                        {% if societe.compte %}
                                            <b>RIB : </b>{{ societe.compte }}
                                        {% endif %}
                                    </td>
                                    <td class="client">
                                        <fieldset>
                                            <legend><b>Code fournisseur : </b>{{ bonCommandeFrs.fournisseur.code }}</legend>
                                            {% if bonCommandeFrs.fournisseur.rs %}
                                                <b>Raison sociale : </b>{{bonCommandeFrs.fournisseur.rs}}<br>
                                            {% endif %}
                                            {% if bonCommandeFrs.fournisseur.mobile %}
                                                <b>Mobile : </b>{{ bonCommandeFrs.fournisseur.mobile }}<br>
                                            {% endif %}
                                            {% if bonCommandeFrs.fournisseur.email %}
                                                <b>Email : </b>{{ bonCommandeFrs.fournisseur.email }}<br>
                                            {% endif %}
                                            {% if bonCommandeFrs.fournisseur.mf %}
                                                <b>M.F : </b>{{ bonCommandeFrs.fournisseur.mf }}<br>
                                            {% endif %}
                                        </fieldset>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <!-- lignes bonreception -->
                    <tr class="heading">
                        <td class="left">Réf</td>
                        <td class="left">Désignation</td>
                        <td class="center">Qte</td>
                    </tr>
                    {% for ligne in bonCommandeFrs.ligneBonCommandeFrss %}
                        <tr class="item">
                            <td class="left">{{ligne.article.code}}</td>
                            <td class="left">{{ligne.designation}}</td>
                            <td class="center">{{ligne.qte}}</td>
                        </tr>
                    {% endfor %}
                </table>
            </div>
        </div>
        <div class="absolute">
            <div class="signatures" style="width: 100%;position: absolute;bottom: 0px;">
                <fieldset style="height:50px;width:29%;display:block;float:left;" >
                    <legend>Note</legend>
                </fieldset>
                <fieldset style="height:50px;width:29%;display:block;float:left;">
                    <legend>Signature Fournisseur</legend>
                </fieldset>
                <fieldset style="height:50px;width:29%;display:block;float:left;">
                    <legend>Signature Societé</legend>
                </fieldset>
            </div>

        </div>
    </body>
    <script type="text/javascript">
        var h = document.getElementById('print').clientHeight;
        if (h > 778) {
            document.getElementById('print').style.height = "2202px";
        }
        
        var myVar = setInterval(myTimer, 0.0000000000000000000000000000000000000000000000001);
        function myTimer() {
            var x = document.readyState;
            if (x === 'complete') {
                window.location.href = "{{ path('boncommandefrs_show',{'id':bonCommandeFrs.id}) }}";
                clearInterval(myVar);
            }
        }
    </script>
</html>
