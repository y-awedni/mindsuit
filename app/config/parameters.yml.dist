# Template for app/config/parameters.yml (which is gitignored).
# Composer's incenteev parameter handler generates parameters.yml from this file
# on `composer install`. The defaults below match the docker-compose dev stack,
# so a fresh clone works out of the box with `make up && make install`.
#
# For native (non-docker) setups, override database_host/mailer_host accordingly.
parameters:
    # Use the compose service name "database" inside docker; "127.0.0.1" natively.
    database_host:     database
    database_port:     3306
    database_name:     mindsuit
    database_user:     mindsuit
    database_password: mindsuit

    # Mailpit listens on port 25 inside the compose network.
    mailer_transport:  smtp
    mailer_host:       mailer
    mailer_user:       no-reply@mindsuit.local
    mailer_password:   ~

    # Generate a real value in production: `openssl rand -hex 32`.
    secret:            ChangeThisToARandom32ByteHexSecret
