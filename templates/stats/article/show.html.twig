{% extends 'base.html.twig' %}
{% block title %}{{ parent()~' - Statistiques d article' }}{% endblock %}
{% block body %}
    <div class="container-fluid container-fluid-fixed-top">
        <section class="content-header">
            <nav class="navbar navbar-default">
                <div class="container-fluid">
                    <ul class="nav navbar-nav navbar-left">
                        <li>
                            <a style="cursor: pointer" href="{{ path('articles_stats') }}">
                                <span class="fa fa-area-chart"></span> Statistiques des articles
                            </a>
                        </li>
                    </ul>
                </div>
            </nav> 
        </section>
        <!-- /.row -->
        <div class="row">
            <div class="col-sm-12">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        <h4 class="panel-title">
                            <a data-toggle="collapse" data-parent="#accordion" href="#collapseOne"><span class="glyphicon glyphicon-chevron-down"></span> Filtrage</a>
                        </h4>
                    </div>
                    <div id="collapseOne" class="panel-collapse collapse">
                        <div class="panel-body">
                            <form role="form" action="{{path('articles_stats_show',{'id':idArticle} )}}" method="GET">
                                <div class="row">
                                    <div class="form-group col-md-6">
                                        <label for="dateCreation">Date</label>
                                        <div class="input-daterange input-group" id="datepicker">
                                            <input type="text" class="form-control" value="{{ app.request.get('startDateCreation')}}" name="startDateCreation" />
                                            <span class="input-group-addon">vers</span>
                                            <input type="text" class="form-control" value="{{ app.request.get('endDateCreation')}}" name="endDateCreation" />
                                        </div>
                                    </div>
                                </div>
                                <input type="hidden"  value="{{ idArticle }}" name="id" />
                                <button type="submit" class="btn btn-info"><span class="glyphicon glyphicon-filter"></span> Filtrer</button>
                                <a href="{{path('articles_stats_id' )}}?id={{idArticle}}" class="btn btn-default"><span class="glyphicon glyphicon-filter"></span> Reinitialiser</a>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        Mouvement d'article en qte
                    </div>
                    <!-- /.panel-heading -->
                    <div class="panel-body">
                        <div id="chart1" class="chart"></div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        Pourcentage de mouvement d'article
                    </div>
                    <!-- /.panel-heading -->
                    <div class="panel-body">
                        <div id="chart2" class="chart"></div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        Mouvement de benifice d'article
                    </div>
                    <!-- /.panel-heading -->
                    <div class="panel-body">
                        <div id="chart3" class="chart"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
{% block javascripts %}
    <script type="text/javascript">
        google.charts.load('current', {packages: ['corechart', 'bar']});
        google.charts.setOnLoadCallback(drawChart1);
        let mouvements = [['', 'Quantité vendus']];
        {% for element in mouvements %}
            {% set typeDoc='' %}
            {% if element.typeDoc=="br" %}
                {% set typeDoc='Bon de réception' %}
            {% elseif element.typeDoc=="bl"  %}
                {% set typeDoc='Bon de livraison' %}
            {% elseif element.typeDoc=="facture"  %}
                {% set typeDoc='Facture' %}
            {% elseif element.typeDoc=="ca"  %}
                {% set typeDoc="Création d'artticle" %}
            {% elseif element.typeDoc=="avc"  %}
                {% set typeDoc='Avoir client' %}
            {% endif %}
                mouvements.push(['{{typeDoc}}', {{element.qte}}]);
        {% endfor %}
            function drawChart1() {
                google.charts.load('current', {'packages': ['bar']});
                google.charts.setOnLoadCallback(drawStuff);
                function drawStuff() {
                    var data = new google.visualization.arrayToDataTable(mouvements);
                    var options = {
                        legend: {position: 'none'},
                        chart: {
                            bars: 'vertical', // Required for Material Bar Charts.
                            axes: {
                                x: {
                                    0: {side: 'bottom', label: 'Quantité'} // Top x-axis.
                                }
                            },
                            bar: {groupWidth: "90%"}
                        }
                    };
                    var chart = new google.charts.Bar(document.getElementById('chart1'));
                    chart.draw(data, options);
                }
            }



            // Load the Visualization API and the corechart package.
            google.charts.load('current', {'packages': ['corechart']});
            // Set a callback to run when the Google Visualization API is loaded.
            google.charts.setOnLoadCallback(drawChart2);
            // Callback that creates and populates a data table,
            // instantiates the pie chart, passes in the data and
            // draws it.
            function drawChart2() {
                // Create the data table.
                var data = new google.visualization.DataTable();
                data.addColumn('string', 'Topping');
                data.addColumn('number', 'Slices');
                data.addRows([{% for element in mouvements %}        {% set typeDoc='' %}
        {% if element.typeDoc=="br" %}
            {% set typeDoc='Bon de réception' %}
        {% elseif element.typeDoc=="bl"  %}
            {% set typeDoc='Bon de livraison' %}
        {% elseif element.typeDoc=="facture"  %}
            {% set typeDoc='Facture' %}
        {% elseif element.typeDoc=="ca"  %}
            {% set typeDoc="Création d/'artticle" %}
        {% elseif element.typeDoc=="avc"  %}
            {% set typeDoc='Avoir client' %}
        {% endif %}
                    ['{{ typeDoc }}', {{ element.qte }}],
        {% endfor %}
                ]);
                var options = {
                    pieHole: 0.4,
                    pieSliceText: 'none'
                };
                // Instantiate and draw our chart, passing in some options.
                var chart = new google.visualization.PieChart(document.getElementById('chart2'));
                chart.draw(data, options);
            }

            //__________________________________________________________________categorie chart
            google.charts.load("current", {packages: ["corechart"]});
            google.charts.setOnLoadCallback(drawChart3);
            function drawChart3() {
                var data = google.visualization.arrayToDataTable([
                    ["Element", "TTC", {role: "style"}],
                    ["Achat", {{ articleAchatTTC }}, "#d9534f"],
                    ["Vente", {{ articleVenteTTC }}, "#5cb85c"],
                    ["Bénifice", {{ articleVenteTTC-articleAchatTTC }}, "#f0ad4e"]
                ]);

                var view = new google.visualization.DataView(data);
                view.setColumns([0, 1,
                    {
                        calc: "stringify",
                        sourceColumn: 1,
                        format: 'short',
                        type: "string",
                        role: "annotation"},
                    2]);

                var options = {
                    bar: {groupWidth: "95%"},
                    legend: {position: "none"}
                };
                var chart = new google.visualization.BarChart(document.getElementById("chart3"));
                chart.draw(view, options);
            }

            $(window).resize(function () {
                drawChart1();
                drawChart2();
                drawChart3();
            });


        </script>
        {% endblock %}
