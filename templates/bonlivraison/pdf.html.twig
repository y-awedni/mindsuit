{% block body %}
    <table class="header">
        <tr>
            <td style="width:25%">
                {% if societe.desactiverPhoto == false and logoPath %}
                    <img src="{{ logoPath }}" style="width:80px;">
                {% endif %}
            </td>
            <td style="width:50%" class="center">
                <span class="doc-title">Bon de Livraison : {{ bonlivraison.code }}</span>
            </td>
            <td style="width:25%" class="right">
                Date : {{ bonlivraison.dateCreation|date("d/m/Y") }}
            </td>
        </tr>
    </table>

    <table class="parties">
        <tr>
            <td class="societe-col">
                {% if societe.adresse %}{{ societe.adresse }}<br>{{ societe.codePostale~' '~societe.ville~' '~societe.pays }}<br>{% endif %}
                {% if societe.tel %}<b>Tél : </b>{{ societe.tel }}<br>{% endif %}
                {% if societe.mobile %}<b>Mobile : </b>{{ societe.mobile }}<br>{% endif %}
                {% if societe.mf %}<b>M.F : </b>{{ societe.mf }}<br>{% endif %}
                {% if societe.rcs %}<b>R.Cs : </b>{{ societe.rcs }}{% endif %}
            </td>
            <td class="client-col">
                <table class="client-box">
                    <tr>
                        <th>Code client : {{ bonlivraison.client.code }}</th>
                    </tr>
                    <tr>
                        <td>
                            {% if bonlivraison.client.rs %}<b>Client : </b>{{ bonlivraison.client.rs }}<br>{% endif %}
                            {% if bonlivraison.client.adresse %}<b>Adresse : </b>{{ bonlivraison.client.adresse }}<br>{% endif %}
                            {% if bonlivraison.client.tel %}<b>Tél : </b>{{ bonlivraison.client.tel }}<br>{% endif %}
                            {% if bonlivraison.client.email %}<b>Email : </b>{{ bonlivraison.client.email }}<br>{% endif %}
                            {% if bonlivraison.client.ville %}<b>Ville : </b>{{ bonlivraison.client.ville }}<br>{% endif %}
                            {% if bonlivraison.client.mf %}<b>M.F : </b>{{ bonlivraison.client.mf }}{% endif %}
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

    <table class="lines">
        <thead>
            <tr>
                <th>Réf</th>
                <th>Désignation</th>
                <th class="center">Unité</th>
                <th class="right">PU HT</th>
                {% if bonlivraison.remise != 0.000 %}<th class="right">Remise</th>{% endif %}
                <th class="center">TVA</th>
                <th class="right">PU TTC</th>
                <th class="right">Qte</th>
                <th class="right">Total TTC</th>
            </tr>
        </thead>
        <tbody>
            {% for ligne in bonlivraison.ligneBonLivraisons %}
                <tr>
                    <td>{{ ligne.article.code }}</td>
                    <td>{{ ligne.designation }}</td>
                    <td class="center">{{ ligne.article.unite }}</td>
                    <td class="right">{{ ligne.prixUnitaire|number_format(3, '.', ' ') }}</td>
                    {% if bonlivraison.remise != 0.000 %}<td class="right">{{ ligne.remise|number_format(0, '.', '') }} %</td>{% endif %}
                    <td class="center">{{ ligne.tva }} %</td>
                    <td class="right">{{ ligne.qte ? (ligne.ttc / ligne.qte)|number_format(3, '.', ' ') : '0.000' }}</td>
                    <td class="right">{{ ligne.qte|number_format(0, '.', '') }}</td>
                    <td class="right">{{ ligne.ttc|number_format(3, '.', ' ') }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}

{% block footer %}
    <table class="summary">
        <tr>
            <td>
                <div class="lettres">
                    Arreté le présent bon de livraison à la somme de:<br>
                    <b>{{ totalDinarsEnTtLettres|upper }} DINARS</b>
                    {% if totalMillimesEnTtLettres %}<b>{{ totalMillimesEnTtLettres }} MILLIMES</b>{% endif %}
                </div>
            </td>
            <td>
                <table class="tva" style="margin-bottom:6px;">
                    <tr>
                        <th class="center">Taux</th>
                        <th class="center">Base</th>
                        <th class="center">TVA</th>
                    </tr>
                    {% for row in tvaBreakdown %}
                        <tr>
                            <td class="right">{{ row.taux }}%</td>
                            <td class="right">{{ row.base|number_format(3, '.', ' ') }}</td>
                            <td class="right">{{ row.tva|number_format(3, '.', ' ') }}</td>
                        </tr>
                    {% endfor %}
                </table>
                <div class="totaux">
                    <table>
                        <tr><th>Total HT</th><td class="right">{{ bonlivraison.ht|number_format(3, '.', ' ') }}</td></tr>
                        {% if bonlivraison.remise != 0.000 %}<tr><th>Total Remise</th><td class="right">{{ bonlivraison.remise|number_format(3, '.', ' ') }}</td></tr>{% endif %}
                        <tr><th>Total TVA</th><td class="right">{{ bonlivraison.tva|number_format(3, '.', ' ') }}</td></tr>
                        <tr><th>Total TTC</th><td class="right"><b>{{ bonlivraison.total|number_format(3, '.', ' ') }}</b></td></tr>
                    </table>
                </div>
            </td>
        </tr>
    </table>

    <table class="signatures">
        <tr>
            <td>Note<br>{{ bonlivraison.note }}</td>
            <td>Signature Client</td>
            <td>Signature Societé</td>
        </tr>
    </table>
{% endblock %}
