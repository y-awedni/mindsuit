{% extends 'base.html.twig' %}

{% block title %}{{ parent()~' - Réglements de fournisseur ' }}{% endblock %}
{% block body %}
    {% set currentPath = path(app.request.attributes.get('_route'),app.request.attributes.get('_route_params')) %}
    {% set currentPath=currentPath~'?a=b' %}
    {% if app.request.get('limit') is not null %}
        {% set currentPath=currentPath~'&limit='~app.request.get('limit') %}
    {% endif %}
    {% if app.request.get('sort') is not null %}
        {% set currentPath=currentPath~'&sort='~app.request.get('sort') %}
    {% endif %}
    {% if app.request.get('direction') is not null %}
        {% set currentPath=currentPath~'&direction='~app.request.get('direction') %}
    {% endif %}
    {% set currentPath=currentPath~'&designation='~app.request.get('designation') %}
    {% set currentPath=currentPath~'&startDateCreation='~app.request.get('startDateCreation') %}
    {% set currentPath=currentPath~'&endDateCreation='~app.request.get('endDateCreation') %}
    {% set currentPath=currentPath~'&typeDoc='~app.request.get('typeDoc') %}
    {% set currentPath=currentPath~'&modeReglement='~app.request.get('modeReglement') %}
    <div class="container-fluid container-fluid-fixed-top">
        {% include 'fiche/fournisseur/menu.html.twig' with { 'fournisseur':fournisseur } %}
        <!-- /.row -->
        <div class="row">
            <div class="col-lg-12">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        <div class="count">
                            {{ total }} réglements du fournisseur <a href="{{ path('fournisseur_show',{'id':fournisseur.id} ) }}">{{ fournisseur }}</a>
                        </div> 
                    </div>
                    <!-- /.panel-heading -->
                    <div class="panel-body">
                        <div class="panel panel-default">
                            <div class="panel-heading">
                                <h4 class="panel-title">
                                    <a data-toggle="collapse" data-parent="#accordion" href="#collapseOne"><span class="glyphicon glyphicon-chevron-down"></span> Filtrage</a>
                                </h4>
                            </div>
                            <div id="collapseOne" class="panel-collapse collapse">
                                <div class="panel-body">
                                    <form method="GET">
                                        <div class="row">
                                            <div class="col-sm-6 ">
                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <div class="form-group">
                                                            <label for="designation">Référence document</label>
                                                            <input class="form-control" name="designation" id="code" value="{{ app.request.get('designation')}}">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="form-group">
                                                            <label for="modeReglement">Mode réglement</label>
                                                            <select name="modeReglement" class="form-control selectpicker">
                                                                <option></option>
                                                                <option {% if app.request.get('modeReglement')=='Espéce' %}selected{% endif %} value="Espéce">Espéce</option>
                                                                <option {% if app.request.get('modeReglement')=='Chéque' %}selected{% endif %} value="Chéque">Chéque</option>
                                                                <option {% if app.request.get('modeReglement')=='Traite' %}selected{% endif %} value="Traite">Traite</option>
                                                                <option {% if app.request.get('modeReglement')=='Banque' %}selected{% endif %} value="Banque">Banque</option>
                                                                <option {% if app.request.get('modeReglement')=='Avoir' %}selected{% endif %} value="Avoir">Avoir</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <div class="form-group">
                                                            <label for="dateCreation">Date</label>
                                                            <div class="input-daterange input-group" id="datepicker">
                                                                <input type="text" class="form-control" value="{{ app.request.get('startDateCreation')}}" name="startDateCreation" />
                                                                <span class="input-group-addon">vers</span>
                                                                <input type="text" class="form-control" value="{{ app.request.get('endDateCreation')}}" name="endDateCreation" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-6">
                                                <div class="form-group">
                                                    <label for="limit">Nombre d'éléments par page </label>
                                                    <select name='limit' class="form-control selectpicker" data-live-search="true">
                                                        <option {% if app.request.get('limit')=='10' %}selected{% endif %} value="10">10 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='25' %}selected{% endif %} value="25">25 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='50' %}selected{% endif %} value="50">50 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='100' %}selected{% endif %} value="100">100 éléments par page</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                        <button type="submit" class="btn btn-info"><span class="glyphicon glyphicon-filter"></span> Filtrer</button>
                                        <a href="{{path('fiche_fournisseur_reglements',{'id':fournisseur.id} )}}" class="btn btn-default"><span class="glyphicon glyphicon-filter"></span> Reinitialiser</a>
                                    </form>
                                </div>
                            </div>
                        </div>
                        <table width="100%" class="table table-striped table-bordered table-hover">
                            <thead>
                                <tr>
                                    {% set direction='ASC' %}
                                    {% if app.request.get('direction') is not null %}
                                        {% set direction=app.request.get('direction')=='DESC'?'ASC':'DESC' %}
                                    {% endif %}
                                    <th><a href="{{ currentPath~"&sort=a.designation&direction="~direction }}">Réference document</a></th>
                                    <th><a href="{{ currentPath~"&sort=a.typeDoc&direction="~direction }}">Type document</a></th>
                                    <th><a href="{{ currentPath~"&sort=a.ttc&direction="~direction }}">Montant TTC</a></th>
                                    <th><a href="{{ currentPath~"&sort=a.modeReglement&direction="~direction }}">Mode réglement</a></th>
                                    <th><a href="{{ currentPath~"&sort=a.dateEcheance&direction="~direction }}">Date écheance</a></th>
                                    <th><a href="{{ currentPath~"&sort=a.numDoc&direction="~direction }}">N°doc</a></th>
                                    <th><a href="{{ currentPath~"&sort=a.etat&direction="~direction }}">Etat</a></th>
                                    <th><a href="{{ currentPath~"&sort=a.dateCreation&direction="~direction }}">Date</a></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for element in pagination %}
                                    <tr>
                                        <td>{{ element.designation }}</td>
                                        <td>
                                            {{ element.typeDoc }}
                                        </td>
                                        <td>{{ element.ttc }}</td>
                                        <td>{{ element.modeReglement }}</td>
                                        <td>{{ element.dateEcheance?element.dateEcheance|date('d-m-Y'):'' }}</td>
                                        <td>{{ element.numDoc }}</td>
                                        <td>{{ element.etat }}</td>
                                        <td>{{ element.dateCreation?element.dateCreation|date('d-m-Y'):'' }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>

                        {% if countCurrentPage >0 %}
                            <ul class="pagination">
                                <li class="prev {% if currentPage==1 %}disabled{% endif %}" {% if currentPage>1 %}style="cursor:pointer"{% endif %}>
                                    <a {% if currentPage>1 %} href="{{ currentPath }}&offset={{currentPage-2}}" {% endif %} title="{% if currentPage!=1 %}page {{currentPage-1}}{% endif %}" >
                                        « Précédent
                                    </a>
                                </li>
                                {% for i in 1..currentPage %}
                                    {% if i!=currentPage %}
                                        <li>
                                            <a href="{{ currentPath }}&offset={{i-1}}">
                                                {{ i }}
                                            </a>
                                        </li>
                                    {% endif %}
                                {% endfor %}
                                <li class="active">
                                    <a>{{ currentPage }}</a>
                                </li>
                                {% for i in currentPage..lastPage %}
                                    {% if i!=currentPage%}
                                        <li>
                                            <a href="{{ currentPath }}&offset={{i-1}}">
                                                {{ i }}
                                            </a>
                                        </li>
                                    {% endif %}
                                {% endfor %}
                                <li class="next {% if currentPage==lastPage %}disabled{% endif %}" {% if currentPage<lastPage %}style="cursor:pointer"{% endif %}>
                                    <a {% if currentPage<lastPage %} href="{{ currentPath }}&offset={{currentPage}}" {% endif %} title="{% if currentPage!=lastPage %}page {{currentPage+1}}{% endif %}">
                                        Suivant »
                                    </a>
                                </li>
                            </ul>
                        {% endif %} 
                    </div>
                    <div class="panel-footer">
                        <a href="{{ path('fiche_fournisseur_reglements_xls',{
                                'designation':app.request.get('designation'),
                                'modeReglement':app.request.get('modeReglement'),
                                'fournisseur':fournisseur.id,
                                'startDateCreation':app.request.get('startDateCreation'),
                                'endDateCreation':app.request.get('endDateCreation') } )}}" class="btn btn-default">
                            <span class="glyphicon glyphicon-download-alt"></span> Exporter en Excel
                        </a>
                    </div>
                </div>
                <!-- totaux -->
                {{ render(controller(
                    'App\\Controller\\TotauxFicheFournisseurController::totauxReglementsAction',
                    {
                        'designation':app.request.get('designation'),
                        'modeReglement':app.request.get('modeReglement'),
                        'fournisseur':fournisseur.id,
                        'startDateCreation':app.request.get('startDateCreation'),
                        'endDateCreation':app.request.get('endDateCreation')
                    }
                )) }}              
            </div>
        </div>
    </div>
{% endblock %}
{% block javascripts %}
    <script type="text/javascript">
        var myVar = setInterval(myTimer, 2000);
        function myTimer() {
            var x = document.readyState;
            if (x === 'complete') {
                document.getElementById('loader').style.display = 'none';
                $('.container-fluid').removeAttr("style");
            }
        }
    </script>
{% endblock %}