<div class="panel panel-green">
    <div class="panel-heading">
        <h4 class="panel-title">
            <a data-toggle="collapse" data-parent="#accordion" href="#collapseTotaux">
                <span class="glyphicon glyphicon-credit-card"></span> 
                Totaux
            </a>
        </h4>
    </div>
    <div id="collapseTotaux" class="panel-collapse collapse in">
        <div class="panel-body">
            <div class="row">
                <div class="col-md-4 col-md-offset-8">
                    <div class="list-group">
                        {% if qte is defined %}
                            <a class="list-group-item">
                                Quantités
                                <span class="pull-right text-muted small"><em>{{ qte }}</em>
                                </span>
                            </a>
                        {% endif %}
                        {% if ttc is defined %}
                            <a class="list-group-item">
                                Total TTC
                                <span class="pull-right text-muted small"><em>{{ ttc|number_format('3','.',' ') }}</em>
                                </span>
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>   
        </div>
    </div>
</div>  