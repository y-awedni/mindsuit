{% extends 'base.html.twig' %}
{% block title %}{{ parent()~' - Notifications ' }}{% endblock %}

{% block body %}
    <div class="container-fluid container-fluid-fixed-top">
        <section class="content-header">
            <nav class="navbar navbar-default">
                <div class="container-fluid">
                    <ul class="nav navbar-nav navbar-left">
                        <li><a href="{{path('notification_vu_all')}}"><span class="glyphicon glyphicon-eye-open"></span> Marquer tous comme vu(s)</a></li>
                    </ul>
                </div>
            </nav>
        </section>
        <!-- /.row -->
        <div class="row">
            <div class="col-lg-12">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        <div class="count">
                            {{ pagination.getTotalItemCount }} Notification(s)
                        </div> 
                    </div>
                    <!-- /.panel-heading -->
                    <div class="panel-body">
                        <div class="panel panel-default">
                            <div class="panel-heading">
                                <h4 class="panel-title">
                                    <a data-toggle="collapse" data-parent="#accordion" href="#collapseOne"><span class="glyphicon glyphicon-chevron-down"></span> Filtrage</a>
                                </h4>
                            </div>
                            <div id="collapseOne" class="panel-collapse collapse">
                                <div class="panel-body">
                                    <form role="form" action="{{path('notification_index')}}" method="GET">
                                        <div class="row">
                                            <div class="col-sm-6">
                                                <div class="form-group row">
                                                    <div class="col-sm-6">
                                                        <label for="description">Description</label>
                                                        <input class="form-control" name="description" id="description" value="{{ app.request.get('description')}}">
                                                    </div>
                                                    <div class="col-sm-6">
                                                        <label for="vu">Vu</label>
                                                        <select name='vu' class="form-control selectpicker" data-live-search="true">
                                                            <option value=""></option>
                                                            <option {% if app.request.get('vu')=='1' %}selected{% endif %} value="1">Oui</option>
                                                            <option {% if app.request.get('vu')=='2' %}selected{% endif %} value="2">Non</option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-6">
                                                <div class="form-group">
                                                    <label for="limit">Nombre d'éléments par page </label>
                                                    <select name='limit' class="form-control selectpicker" data-live-search="true">
                                                        <option {% if app.request.get('limit')=='10' %}selected{% endif %} value="10">10 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='25' %}selected{% endif %} value="25">25 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='50' %}selected{% endif %} value="50">50 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='100' %}selected{% endif %} value="100">100 éléments par page</option>
                                                    </select>
                                                </div>
                                                <div class="form-group">
                                                </div>
                                            </div>
                                        </div>
                                        <button type="submit" class="btn btn-info"><span class="glyphicon glyphicon-filter"></span> Filtrer</button>
                                        <a href="{{path('notification_index')}}" class="btn btn-default"><span class="glyphicon glyphicon-filter"></span> Reinitialiser</a>

                                    </form>

                                </div>
                            </div>
                        </div>
                        <table width="100%" class="table table-striped table-bordered table-hover">
                            <thead>
                                <tr>
                                    <th>{{ knp_pagination_sortable(pagination, 'Description', 'a.description') }}</th>
                                    <th>{{ knp_pagination_sortable(pagination, 'Vu', 'a.vu') }}</th>
                                    <th>{{ knp_pagination_sortable(pagination, 'Date', 'a.createdAt') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for notification in pagination %}
                                    <tr>
                                        <td><a onclick="changeNotificationVu({{ notification.id }})" href="{{ path(notification.url,{ 'id':notification.valueId}) }}">{{ notification.description }}</a></td>
                                        <td>
                                            {% if notification.vu %}
                                                <em class="label label-success"><span class="glyphicon glyphicon-eye-open"></span> Oui</em>
                                            {% else %}
                                                <em class="label label-danger"><span class="glyphicon glyphicon-eye-close"></span> Non</em>
                                            {% endif %}
                                        </td>
                                        <td>{% if notification.createdAt %}{{ notification.createdAt|date('H:i:s d-m-Y ') }}{% endif %}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        <div class="navigation">
                            {{ knp_pagination_render(pagination) }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
{% block javascripts %}
    <script type="text/javascript">
        function changeNotificationVu(id) {
            jQuery.ajax({
                method: "POST",
                url: "{{ path('changeNotificationVu') }}",
                data: {
                    id: id
                }
            }).done(function (data) {
                if (!data.success) {
                    event.preventDefault();
                }
            });
        }
    </script>
{% endblock %}
