<html>
    <head>
        <title>{{ factureAvoir.code }}</title>
        <style>
            .print-box {
                font-size: 8px;
                line-height: 18px;
                font-family: 'Helvetica Neue', 'Helvetica', Helvetica, Arial, sans-serif;
                color: #555;
            }
            .print-box table tr.information table td{
                font-size: 14px;
            }
            .print-box table {
                width: 100%;
                line-height: inherit;
                text-align: left;
            }
            .print-box table td {
                padding: 3px;
                vertical-align: top;
            }
            .print-box table tr td:nth-child(2) {
                text-align: right;
            }
            .print-box table tr.top table td {
                padding-bottom: 20px;

            }

            .print-box table tr.top table td.title {
                font-size: 45px;
                line-height: 45px;
                color: #333;
            }
            .print-box table tr.top table td.code {
                width: 70%;
                text-align: left;
            }
            .print-box table tr.information table td {
                padding-bottom: 40px;
            }
            .print-box table tr.information table td.societe {
                width: 50%;
            }
            .print-box table tr.information table td.client {
                width: 30%;
                text-align: left;
            }
            .print-box table tr.heading td {
                background: #13b3d9;
                border-bottom: 1px solid #ddd;
                font-weight: bold;
                font-size: 12px;
            }
            .print-box table tr.details td {
                padding-bottom: 20px;
            }
            .print-box table tr.item td {
                border-bottom: 1px solid #eee;
                font-size: 12px;
            }
            .print-box table tr.item:nth-child(odd) {background: #eee;}
            .print-box table tr.item:nth-child(even) {background: #fff;}

            .print-box table tr.item.last td {
                border-bottom: none;
            }
            .print-box table tr.total td:nth-child(2) {
                border-top: 2px solid #eee;
                font-weight: bold;
            }
            .center{
                text-align:center;
            }
            .left{
                text-align: left!important;
            }
            .right{
                text-align: right!important;
            }
            .print-box table tr.bottom td table{
                padding-top: 10px;
                font-size: 14px;
            }
            div.totaux{
                width: 30%;
                position: absolute;
                top: 0;
                right: 0;
            }
            div.totaux table{
                border: 1px solid #ddd;
                border-collapse: collapse;
                width: 100%;
            }
            div.totaux table th{
                background: #eee;
                width: 50%;
            }
            div.baseTva{
                width: 25%;
                position: absolute;
                top: 0;
                right: 240px;
            }

            div.baseTva table.tableauTVA{
                width: 100%;
                float: right;
                border: 1px solid #ddd;
                border-collapse: collapse;
            }
            div.baseTva table.tableauTVA td{
                font-size: 16px!important;
            }

            .font16{
                font-size: 16px!important;
            }

            div.baseTva table thead{
                background: #13b3d9;
                border-bottom: 1px solid #ddd;
                font-weight: bold;
                font-size: 12px;
            }
            div.baseTva table tbody tr:nth-child(odd) {background: #eee;}
            div.baseTva table tbody tr:nth-child(even) {background: #fff;}

            @media only screen and (max-width: 600px) {
                .print-box table tr.top table td {
                    width: 100%;
                    display: block;
                    text-align: center;
                }
                .print-box table tr.information table td {
                    width: 100%;
                    display: block;
                    text-align: center;
                }
            }

            body.relative {
                position: relative;
            }
            div.absolute {
                position: absolute;
                bottom: 0px;
                right: 4px;
                width: 98%;
                height: 180px;
                font-size:12px
            }
        </style>
    </head>
    <body class="relative" onload="window.print();
            window.close();">
        <div id="print" >
            <div class="print-box">
                <table cellpadding="0" cellspacing="0" >
                    <tr class="top">
                        <td colspan="9">
                            <table>
                                <tr>
                                    <td class="title" style="width: 20%">
                                        {% if societe.desactiverPhoto==false and societe.media %}
                                            <img style="width:75px; max-width:200px;" src="{{ asset(societe.media.assetPath) }}">
                                        {% endif %}
                                    </td>
                                    <td class="code" style="width: 60%;text-align: center">
                                        <h2><strong>Avoir client </strong>: {{ factureAvoir.code }}</h2>
                                    </td>
                                    <td class="date" style="width: 20%;text-align: right">
                                        Date : {{ factureAvoir.dateCreation|date("d/m/Y")}}
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr class="information">
                        <td colspan="9">
                            <table>
                                <tr>
                                    <td class="societe">
                                        {% if societe.adresse %}
                                            {{societe.adresse}}<br>
                                            {{societe.codePostale~' '~societe.ville~' '~societe.pays}}<br>
                                        {% endif %}

                                        {% if societe.tel %}
                                            <b>Tél-Fax : </b>{{societe.tel}}<br>
                                        {% endif %}
                                        {% if societe.mobile %}
                                            <b>Mobile : </b>{{ societe.mobile }}<br>
                                        {% endif %}
                                        {% if societe.email %}
                                            <b>Email : </b>{{ societe.email }}<br>
                                        {% endif %}
                                        {% if societe.mf %}
                                            <b>M.F : </b>{{ societe.mf }}<br>
                                        {% endif %}
                                        {% if societe.rcs %}
                                            <b>R.Cs : </b>{{ societe.rcs }}
                                        {% endif %}<br>
                                        {% if societe.compte %}
                                            <b>RIB : </b>{{ societe.compte }}
                                        {% endif %}
                                    </td>

                                    <td class="client">
                                        {% set facture=factureAvoir.facture %}
                                        <fieldset>
                                            <legend><b>Code client : </b>{{ facture.client.code }}</legend>
                                            {% if facture.client.rs %}
                                                <b>Client : </b>{{facture.client.rs}}<br>
                                            {% endif %}
                                            {% if facture.client.email %}
                                                <b>Email : </b>{{ facture.client.email }}<br>
                                            {% endif %}
                                            {% if facture.client.ville %}
                                                <b>Ville : </b>{{ facture.client.ville }}<br>
                                            {% endif %}
                                            {% if facture.client.mf %}
                                                <b>M.F : </b>{{ facture.client.mf }}<br>
                                            {% endif %}
                                        </fieldset>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- lignes facture -->
                    <tr class="heading">
                        <td class="left">Réf</td>
                        <td class="left">Désignation</td>
                        <td class="left">Unité</td>
                        <td class="center">PU HT</td>
                        <td class="center">Remise</td>
                        <td class="center">TVA</td>
                        <td class="center">PU TTC</td>
                        <td class="center">Qte</td>
                        <td class="center">Total TTC</td>
                    </tr>
                    {% set i=0 %}
                    {% for ligne in factureAvoir.ligneFactureAvoirs %}
                        <tr class="item">
                            <td class="left">{{ligne.article.code}}</td>
                            <td class="left">{{ligne.designation}}</td>
                            <td class="left">{{ligne.article.unite}}</td>
                            <td class="center" id="prixUnitaire_{{i}}">{{ligne.prixUnitaire}}</td>
                            <td class="center" id="remise_{{i}}">{{ligne.remise}} %</td>
                            <td class="center" id="tva_{{i}}">{{ligne.tva }} %</td>
                            {% set puTTC=ligne.ttc/ligne.qte %}
                            <td class="center" id="ttc_{{i}}">{{ puTTC|number_format(3, '.', '') }}</td>
                            <td class="center" id="qte_{{i}}">{{ligne.qte}}</td>
                            <td class="center" id="total_{{i}}">{{ligne.ttc }}</td>
                        </tr>
                        {% set i=i+1 %}
                    {% endfor %}
                    <div id="lignesFacturesLength" style="visibility: hidden">{{i}}</div>
                </table>
            </div>
        </div>
        <div class="absolute">
            <div style="width: 45%">
                Arreté la présente facture avoir à la somme de:<br>
                {{ totalDinarsEnTtLettres|upper }} DINARS<br>
                {% if totalMillimesEnTtLettres %}
                    {{ totalMillimesEnTtLettres }} MILLIMES
                {% endif %}
            </div>
            <div class="baseTva" id="tvaTable">
                <table class="tableauTVA">
                    <thead>
                        <tr>
                            <th class="center font16">Taux</th>
                            <th class="center font16">Base</th>
                            <th class="center font16">TVA</th>
                        </tr>
                    </thead>
                    <tbody id="baseTVA">
                        <tr>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="totaux" id='totauxTable'>
                <table class="font16">
                    <tr>
                        <th class="left">Total HT</th>
                        <td class="right" >{{ facture.ht }}</td>
                    </tr>
                    <tr>
                        <th class="left">Total Remise</th>
                        <td class="right">{{ facture.remise }}</td>
                    </tr>
                    <tr>
                        <th class="left">Total TVA</th>
                        <td class="right">{{ facture.tva }}</td>
                    </tr>
                    <tr>
                        <th class="left">Timbre</th>
                        <td class="right">{{ facture.timbre }}</td>
                    </tr>
                    <tr>
                        <th class="left">Total TTC</th>
                        <td class="right">{{ facture.total }}</td>
                    </tr>
                </table>
            </div>

            <div class="signatures" style="width: 100%;position: absolute;bottom: 0px;">
                <fieldset style="height:50px;width:29%;display:block;float:left;" >
                    <legend>Note</legend>
                </fieldset>
                <fieldset style="height:50px;width:29%;display:block;float:left;">
                    <legend>Signature Client</legend>
                </fieldset>
                <fieldset style="height:50px;width:29%;display:block;float:left;">
                    <legend>Signature Societé</legend>
                </fieldset>
            </div>

        </div>
    </body>
    <script type="text/javascript">
        var h = document.getElementById('print').clientHeight;
        if (h > 778) {
            document.getElementById('print').style.height = "2202px";
        }
        var lignesFacturesLength = document.getElementById('lignesFacturesLength').innerHTML;
        Array.prototype.inArray = function (value)
        {
            // Returns true if the passed value is found in the
            // array. Returns false if it is not.
            var i;
            for (i = 0; i < this.length; i++)
            {
                if (this[i] === value)
                {
                    return true;
                }
            }
            return false;
        };
        var ttc = 0;        //total TTC
        var ht = 0;         //total HT
        var remise = 0;     //total REMISE
        var tva = 0;        //total TVA
        var perCentTva = [];//taux TVA[]
        var baseTva = [];   //base TVA[]
        var ttTva = [];     //total TVA[]
        var _tvaa = '';     //tr TVA[]
        if (lignesFacturesLength > 0) {
            for (var i = 0; i < lignesFacturesLength; i++) {
                //calcule ttc pu remise tva_____________________________
                //incrementation du ttc
                ttc += Number(parseFloat(document.getElementById('total_' + i).innerHTML).toFixed(3));
                //recuperation des input________________________________
                //input prix unitaire
                var pu = Number(parseFloat(document.getElementById('prixUnitaire_' + i).innerHTML).toFixed(3));
                //input qte
                var qte = Number(parseFloat(document.getElementById('qte_' + i).innerHTML).toFixed(3));
                //input remise
                var _remise = Number(parseFloat(document.getElementById('remise_' + i).innerHTML).toFixed(3));
                //input tva
                var _tva = Number(parseFloat(document.getElementById('tva_' + i).innerHTML).toFixed(3));
                //  calcule de cette ligne _____________________________
                //prix hors taxe avant remise de cette ligne
                var __htAvantRemise = pu * qte;
                //remise de cette ligne d'un seul article
                var __remise = (__htAvantRemise / 100 * _remise);
                //prix hors taxe apres remise de cette ligne
                var __htApresRemise = __htAvantRemise - __remise;
                //tva de cette ligne
                var __tva = __htApresRemise / 100 * _tva;
                // incrementation des variables totaux
                // prix ht
                ht += __htAvantRemise;
                //remise
                remise += __remise;
                //tva
                tva += __tva;

                //calcule du tableau tva
                if (!perCentTva.inArray(_tva)) {
                    perCentTva.push(_tva);
                    var __baseTva = (__htAvantRemise) - ((__htAvantRemise) / 100 * _remise);
                    baseTva.push(__baseTva);
                    ttTva.push(__baseTva / 100 * _tva);
                } else {
                    var index = perCentTva.indexOf(_tva);
                    var __baseTva = (__htAvantRemise) - ((__htAvantRemise) / 100 * _remise);
                    var _baseTva = Number(parseFloat(baseTva[index]).toFixed(3));
                    baseTva[index] = _baseTva + __baseTva;

                    var __ttTva = __baseTva / 100 * _tva;
                    var _ttTva = Number(parseFloat(ttTva[index]).toFixed(3));
                    ttTva[index] = _ttTva + __ttTva;
                }

            }
        }
        for (var i = 0; i < perCentTva.length; i++) {
            _tvaa += "<tr><td class='right font16'>" + perCentTva[i] + "%</td><td class='right font16'>" + baseTva[i].toFixed(3) + "</td><td class='right font16'>" + ttTva[i].toFixed(3) + "</td></tr>";
        }
        document.getElementById('baseTVA').innerHTML = _tvaa;

        var myVar = setInterval(myTimer, 1);
        function myTimer() {
            var x = document.readyState;
            if (x === 'complete') {
                window.location.href = "{{ path('factureavoir_show',{'id':factureAvoir.id}) }}";
                clearInterval(myVar);
            }
        }
    </script>
</html>
