{% extends 'base.html.twig' %}
{% block title %}{{ parent()~' - Avoirs clients sur '~facture }}{% endblock %}
{% block body %}
    <div class="container-fluid container-fluid-fixed-top">
        <section class="content-header">
            <nav class="navbar navbar-default">
                <div class="container-fluid">
                    <ul class="nav navbar-nav navbar-left">
                        <li><a href="{{path('factureavoir_facture_new',{'id':facture.id} )}}"><span class="glyphicon glyphicon-plus"></span> Ajouter</a></li>
                    </ul>
                </div>
            </nav> 
        </section>
        <!-- /.row -->
        <div class="row">
            <div class="col-lg-12">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        <div class="count">
                            {{ pagination.getTotalItemCount }} factures avoirs sur la facture <a href="{{ path('facture_show',{'id':facture.id } ) }}">{{ facture }}</a>
                        </div> 
                    </div>
                    <!-- /.panel-heading -->
                    <div class="panel-body">
                        <table width="100%" class="table table-striped table-bordered table-hover">
                            <thead>
                                <tr>
                                    <th>{{ knp_pagination_sortable(pagination, 'Code', 'a.code') }}</th>
                                    <th>Facture</th>
                                    <th {% if pagination.isSorted('a.termine') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, 'Etat', 'a.termine') }}</th>
                                    <th {% if pagination.isSorted('a.total') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, 'Total', 'a.total') }}</th>
                                    <th {% if pagination.isSorted('a.dateCreation') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, 'Date de création', 'a.dateCreation') }}</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for ligne in pagination %}
                                    <tr>
                                        <td>{{ ligne.code }}</td>
                                        <td>{{ ligne.facture }}</td>
                                        <td>
                                            <em class="label label-{{ ligne.termine?'success':'warning' }}">
                                                {{ ligne.termine?'Terminé':'En cours' }}
                                            </em>
                                        </td>
                                        <td>{{ ligne.total|number_format('3','.',' ') }}</td>
                                        <td>{{ ligne.dateCreation|date("d/m/Y") }}</td>
                                        <td>
                                            <a title="Pour modifier cet avoir il faut le terminer" {{ ligne.termine?"disabled onclick='return false'":"" }} class="btn btn-primary btn-xs" href="{{ path('factureavoir_edit', { 'id': ligne.id }) }}"><span class="glyphicon glyphicon-edit"></span> Modifier</a>
                                            <a class="btn btn-success btn-xs" href="{{ path('factureavoir_show', { 'id': ligne.id }) }}"><span class="glyphicon glyphicon-eye-open"></span> Afficher</a>
                                            
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        <div class="navigation">
                            {{ knp_pagination_render(pagination) }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
