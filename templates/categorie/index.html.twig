{% extends 'base.html.twig' %}
{% block title %}{{ parent()~' - Catégories articles' }}{% endblock %}
{% block body %}
    <div class="container-fluid container-fluid-fixed-top">
        <section class="content-header">
            <nav class="navbar navbar-default">
                <div class="container-fluid">
                    <ul class="nav navbar-nav navbar-left">
                        <li><a href="{{path('categorie_new')}}"><span class="glyphicon glyphicon-plus"></span> Ajouter</a></li>
                    </ul>
                </div>
            </nav> 
        </section>
        <!-- /.row -->
        <div class="row">
            <div class="col-lg-12">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        Liste des Catégories
                    </div>
                    <!-- /.panel-heading -->
                    <div class="panel-body">
                        <table width="100%" class="table table-striped table-bordered table-hover">
                            <thead>
                                <tr>
                                    <th>Libellé</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for categorie in categories %}
                                    <tr>
                                        <td>{{ categorie.libelle }}</td>
                                        <td>
                                            <a class="btn btn-primary btn-xs" href="{{ path('categorie_edit', { 'id': categorie.id }) }}"><span class="glyphicon glyphicon-edit"></span> Modifier</a>
                                            <button class="btn btn-danger btn-xs" data-toggle="modal" data-target="#myModal{{categorie.id}}">
                                                <span class="glyphicon glyphicon-remove"></span> Supprimer
                                            </button>
                                            <!-- Modal -->
                                            <div class="modal fade" id="myModal{{categorie.id}}" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
                                                <div class="modal-dialog">
                                                    <div class="modal-content">
                                                        <div class="modal-header">
                                                            <button type="button" class="close" data-dismiss="modal" aria-hidden="true">&times;</button>
                                                            <h4 class="modal-title" id="myModalLabel">{{ categorie }}</h4>
                                                        </div>
                                                        <div class="modal-body">
                                                            Voulez-vous supprimer cette categorie
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-default" data-dismiss="modal">Fermer</button>
                                                            <a href="{{ path('categorie_delete', { 'id': categorie.id }) }}" class="btn btn-danger"><span class="glyphicon glyphicon-remove"></span> Supprimer</a>
                                                        </div>
                                                    </div>
                                                    <!-- /.modal-content -->
                                                </div>
                                                <!-- /.modal-dialog -->
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
