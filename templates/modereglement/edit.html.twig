{% extends 'base.html.twig' %}

{% block body %}
    <div id="page-wrapper">
        <section class="content-header">
            <nav class="navbar navbar-default">
                <div class="container-fluid">
                    <ul class="nav navbar-nav navbar-right">
                        <li><a href="{{path('modereglement_index')}}"><span class="glyphicon glyphicon-th-list"></span> Liste</a></li>
                    </ul>
                </div>
            </nav> 
        </section>
        <!-- /.row -->
        <div class="row">
            <div class="col-lg-12">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        Mode de Réglement {{ modeReglement }}
                    </div>
                    <!-- /.panel-heading -->
                    <div class="panel-body">
                        {% form_theme edit_form 'bootstrap_3_layout.html.twig' %}
                        {{ form_start(edit_form) }}
                        {{ form_widget(edit_form) }}
                        <button type="submit" class="btn btn-success"><i class="fa fa-save"></i> Modifier</button>
                        {{ form_end(edit_form) }}
                    </div>
                    <div class="panel-footer">
                        {% form_theme delete_form 'bootstrap_3_layout.html.twig' %}
                        {{ form_start(delete_form) }}
                        <button type="submit" class="btn btn-danger"><i class="glyphicon glyphicon-floppy-remove"></i> Supprimer</button>
                        {{ form_end(delete_form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
