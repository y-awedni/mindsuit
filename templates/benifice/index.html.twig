{% extends 'base.html.twig' %}
{% block title %}{{ parent()~' - Factures' }}{% endblock %}
{% block body %}
    <div class="container-fluid container-fluid-fixed-top">
        <section class="content-header">
            <nav class="navbar navbar-default">
                <div class="container-fluid">
                    <ul class="nav navbar-nav navbar-left">
                        <li><a href="{{path('facture_new')}}"><span class="glyphicon glyphicon-plus"></span> Ajouter</a></li>
                    </ul>
                </div>
            </nav> 
        </section>
        <!-- /.row -->
        <div class="row">
            <div class="col-lg-12">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        <div class="count">
                            {{ pagination.getTotalItemCount }} Factures
                        </div> 
                    </div>
                    <!-- /.panel-heading -->
                    <div class="panel-body">
                        <div class="panel panel-default">
                            <div class="panel-heading">
                                <h4 class="panel-title">
                                    <a data-toggle="collapse" data-parent="#accordion" href="#collapseOne"><span class="glyphicon glyphicon-chevron-down"></span> Filtrage</a>
                                </h4>
                            </div>
                            <div id="collapseOne" class="panel-collapse collapse">
                                <div class="panel-body">
                                    <form role="form" action="{{path('facture_benifice_index')}}" method="GET">
                                        <div class="row">
                                            <div class="col-sm-6 ">
                                                <div class="row">
                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label for="code">Code</label>
                                                            <input class="form-control" name="code" id="code" value="{{ app.request.get('code')}}">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label for="total">Total</label>
                                                            <input class="form-control" name="total" id="total" value="{{ app.request.get('total')}}">
                                                        </div>
                                                    </div>
                                                    <div class="col-md-4">
                                                        <div class="form-group">
                                                            <label for="client">Client</label>
                                                            <select name='client' class="form-control selectpicker" data-live-search="true">
                                                                <option value=""></option>
                                                                {% for client in clients %}
                                                                    <option {% if app.request.get('client')==client.id %}selected{% endif %} value="{{ client.id }}">
                                                                        {% if client.rs %}
                                                                            {{ client.rs }}
                                                                        {% else %}
                                                                            code:#{{ client.code }}
                                                                        {% endif %}
                                                                    </option>
                                                                {% endfor %}
                                                            </select>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <div class="form-group">
                                                            <label for="dateCreation">Date de création</label>
                                                            <div class="input-daterange input-group" id="datepicker">
                                                                <input type="text" class="form-control" value="{{ app.request.get('startDateCreation')}}" name="startDateCreation" />
                                                                <span class="input-group-addon">vers</span>
                                                                <input type="text" class="form-control" value="{{ app.request.get('endDateCreation')}}" name="endDateCreation" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <div class="form-group">
                                                            <label for="dateEcheance">Date d'écheance</label>
                                                            <div class="input-daterange input-group" id="datepicker">
                                                                <input type="text" class="form-control" value="{{ app.request.get('startDateEcheance')}}" name="startDateEcheance" />
                                                                <span class="input-group-addon">vers</span>
                                                                <input type="text" class="form-control" value="{{ app.request.get('endDateEcheance')}}" name="endDateEcheance" />
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-6">
                                                <div class="form-group">
                                                    <label for="limit">Nombre d'éléments par page </label>
                                                    <select name='limit' class="form-control selectpicker" data-live-search="true">
                                                        <option {% if app.request.get('limit')=='10' %}selected{% endif %} value="10">10 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='25' %}selected{% endif %} value="25">25 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='50' %}selected{% endif %} value="50">50 éléments par page</option>
                                                        <option {% if app.request.get('limit')=='100' %}selected{% endif %} value="100">100 éléments par page</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                        <button type="submit" class="btn btn-info"><span class="glyphicon glyphicon-filter"></span> Filtrer</button>
                                        <a href="{{path('facture_benifice_index')}}" class="btn btn-default"><span class="glyphicon glyphicon-filter"></span> Reinitialiser</a>
                                    </form>
                                </div>
                            </div>
                        </div>
                        <table width="100%" class="table table-striped table-bordered table-hover">
                            <thead>
                                <tr>
                                    <th>{{ knp_pagination_sortable(pagination, 'Code', 'a.code') }}</th>
                                    <th>Client</th>
                                    <th {% if pagination.isSorted('a.total') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, 'Total', 'a.total') }}</th>
                                    <th {% if pagination.isSorted('a.benifice') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, 'Benifice', 'a.benifice') }}</th>
                                    <th {% if pagination.isSorted('a.regle') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, 'Déja réglé', 'a.regle') }}</th>
                                    <th {% if pagination.isSorted('a.regle') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, 'Reste', 'a.regle') }}</th>
                                    <th {% if pagination.isSorted('a.dateCreation') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, 'Date de création', 'a.dateCreation') }}</th>
                                    <th {% if pagination.isSorted('a.dateEcheance') %} class="sorted"{% endif %}>{{ knp_pagination_sortable(pagination, "Date d'échéance", 'a.dateEcheance') }}</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for facture in pagination %}
                                    <tr>
                                        <td>{{ facture.code }}</td>
                                        <td>{{ facture.client }}</td>
                                        <td>{{ facture.total|number_format('3','.',' ') }}</td>
                                        <td>
                                            <em class="label label-{{facture.benifice>0?'success':'danger'}}">
                                                {{ facture.benifice|number_format('3','.',' ') }}
                                            </em>
                                        </td>
                                        <td>{{ facture.regle|number_format('3','.',' ') }}</td>
                                        <td class="center">{{ facture.reste|number_format('3','.',' ') }}</td>
                                        <td>{{ facture.dateCreation|date("d/m/Y") }}</td>
                                        <td>{{ facture.dateEcheance|date("d/m/Y") }}</td>
                                        <td>
                                            <a class="btn btn-primary btn-xs" href="{{ path('facture_edit', { 'id': facture.id }) }}"><span class="glyphicon glyphicon-edit"></span> Modifier</a>
                                            <a class="btn btn-success btn-xs" href="{{ path('facture_benifice_show', { 'id': facture.id }) }}"><span class="glyphicon glyphicon-eye-open"></span> Afficher</a>
                                            <a class="btn btn-warning btn-xs" href="{{ path('facture_reglements', { 'id': facture.id }) }}"><span class="fa fa-money"></span> Réglements</a>
                                            <a class="btn btn-info btn-xs" href="{{ path('factureavoir_facture', { 'id': facture.id }) }}"><span class="fa fa-reply-all"></span> Avoirs</a>
                                            
                                        </td>
                                    </tr>
                                {% endfor %}
                                <tr>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td>
                                        <h3 style="margin-top: 0px;
    margin-bottom: 4px;">
                                            {{ render(controller('App\\Controller\\BenificeController::getBeneficeAction',{
                                                'code': app.request.get('code'),
                                                'total': app.request.get('total'),
                                                'client': app.request.get('client'),
                                                'startDateCreation': app.request.get('startDateCreation'),
                                                'endDateCreation': app.request.get('endDateCreation'),    
                                                'startDateEcheance': app.request.get('startDateEcheance'),  
                                                'endDateEcheance': app.request.get('endDateEcheance')
                                            } )) }}
                                        </h3>
                                    </td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                            </tbody>
                        </table>
                        <div class="navigation">
                            {{ knp_pagination_render(pagination) }}
                        </div>
                    </div>
                    <div class="panel-footer">
                        <form action="{{ path('facture_index') }}">
                            <input type="hidden" name="code" value="{{ app.request.get('code')}}">
                            <input type="hidden" name="total" value="{{ app.request.get('total')}}">
                            <input type="hidden" name="client" value="{{ app.request.get('client') }}" >
                            <input type="hidden" name="startDateCreation" value="{{ app.request.get('startDateCreation')}}"  />
                            <input type="hidden" name="endDateCreation"  value="{{ app.request.get('endDateCreation')}}" />
                            <input type="hidden" name="startDateEcheance"  value="{{ app.request.get('startDateEcheance')}}" />
                            <input type="hidden" name="endDateEcheance" value="{{ app.request.get('endDateEcheance')}}"  />
                            <input type="hidden" name="print" value="1">
                            <button type="submit" class="btn btn-success">
                                <span class="fa fa-print"> Imprimer</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
{% block javascripts %}
    <script type="text/javascript">
        /*
         * Nous sommes dans le scope global,
         * aussi l'objet `keys` est accessible partout
         * dans le code à travers tous les fichiers JavaScript.
         */
        var keys = {};
        /*
         * Étant dans le code global,
         * `window.onkeydown` est identique à `this.onkeydown` 
         * lui même identique à `onkeydown`.
         * On associe ci-dessous la même fonction lorsqu'une
         * touche est appuyée, et lorsqu'une touche est relachée.
         */
        onkeydown = onkeyup = function (e) {
            /*
             * Si `e` n'existe pas, 
             * nous somme probablement dans un vieux IE.
             * On affecte alors `event` à `e`.
             */
            e = e || event;
            /*
             * Si la fonction courante est executée, 
             * quand une touche est enfoncée,
             * `e.type === 'keydown'` renverra `true`
             * sinon elle renverra `false`.
             * Il suffit alors d'assigner chaque état 
             * dans le tableau `keys` pour chaque
             * touche `e.keyCode`.
             */
            keys[e.keyCode] = e.type === 'keydown';
            /*
             * Cette zone sera exécutée lorsque les touches
             * Ctrl (17) et b (66)
             * seront enfoncée en même temps
             * car l'objet `keys` vaudra alors :
             * {
             *  17: true,
             *  18: true,
             *  69: true
             * }
             */
            if (keys[17] && keys[66]) {
                window.location.href="{{ path('facture_index') }}";
            }
        }
    </script>
{% endblock %}
