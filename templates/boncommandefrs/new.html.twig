{% extends 'base.html.twig' %}
{% block title %}{{ parent()~' - Ajout Bon de commande fournisseur' }}{% endblock %}

{% block body %}
    <script type="text/javascript">
        var $arrayOfIndexes = [];
        var $cmp = 0;
    </script>
    <div class="container-fluid container-fluid-fixed-top">
        <section class="content-header">
            <nav class="navbar navbar-default">
                <div class="container-fluid">
                    <ul class="nav navbar-nav navbar-left">
                        <li><a href="{{path('boncommandefrs_index')}}"><span class="glyphicon glyphicon-align-justify"></span> Liste</a></li>
                    </ul>
                </div>
            </nav> 
        </section>
        <!-- /.row -->
        <div class="row">
            <div class="col-lg-12">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        Ajout du bon de commande fournisseur
                    </div>
                    <!-- /.panel-heading -->
                    <div class="panel-body">
                        <!-- Modal Custom Fournisseur -->
                        {% include 'modal/fournisseur.html.twig' %}
                        <!-- Modal Custom Article -->
                        {% include 'modal/produit.html.twig' %}
                        {{ form_start(form) }}
                        <!-- entete -->
                        <div class="panel panel-info">
                            <div class="panel-heading">
                                <h4 class="panel-title">
                                    <a data-toggle="collapse" data-parent="#accordion" href="#collapseOne">
                                        <span class="glyphicon glyphicon-align-justify"></span> 
                                        Détails du bon de commande fournisseur
                                    </a>
                                </h4>
                            </div>
                            <div id="collapseOne" class="panel-collapse collapse in">
                                <div class="panel-body">
                                    {% form_theme form 'bootstrap_3_layout.html.twig' %}
                                    <div class="row">
                                        <div class="col-sm-12 col-md-6 col-lg-6">
                                            {{ form_row(form.code) }}
                                        </div>
                                        <div class="col-sm-8 col-md-4 col-lg-4">
                                            {{ form_row(form.fournisseur) }}
                                        </div>
                                        <div class="col-sm-4 col-md-2 col-lg-2">
                                            <label class="control-label" title='Ajouter un fournisseur rapidement'>Nouveau fournisseur ?</label>
                                            <a style="width: 100%" title='Ajouter un fournisseur rapidement' class='btn btn-success' data-toggle='modal' data-target='#fournisseurCustomNew'>
                                                <span class='fa fa-plus'></span> Ajouter fournisseur
                                            </a>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-6">
                                            {{ form_row(form.note) }}
                                        </div>
                                        <div class="col-sm-3">
                                            {{ form_row(form.dateCreation) }}
                                        </div>
                                        <div class="col-sm-3">
                                            {{ form_row(form.dateCommande) }}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- lignes -->
                        <div class="panel panel-primary">
                            <div class="panel-heading">
                                <h4 class="panel-title">
                                    <a data-toggle="collapse" data-parent="#accordion" href="#collapseTwo"><span class="glyphicon glyphicon-tasks"></span> Lignes du bon de commande fournisseur</a>
                                </h4>
                            </div>
                            {{ form_errors(form) }}
                            {% macro prototype_lignes(ligne) %}
                                <div class="col-md-4">
                                    <div class="row">
                                        <div class="col-xs-10"> 
                                            {{ form_row(ligne.article,{'label':false,'required':false,'attr':{'onchange':'changeArticle(this)' }} ) }}
                                        </div>
                                        <div class="col-xs-1"> 
                                            <a onclick="articleCustomNewFn(this);" title='Ajouter un article rapidement' class='btn btn-success' data-toggle='modal' data-target='#articleCustomNew'>
                                                <span class='fa fa-plus'></span>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-5">{{ form_row(ligne.designation,{'label':false,'required':false,'attr':{'style': 'height:34px!important'} }) }}</div>
                                <div class="col-md-2">{{ form_row(ligne.qte,{'label':false,'required':false,'attr':{'autocomplete':'off' }} ) }}</div>
                            {% endmacro %}
                            <div id="collapseTwo" class="panel-collapse collapse in">
                                <div class="panel-body">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label class="control-label">Article</label>
                                            </div>
                                        </div>
                                        <div class="col-md-5">
                                            <div class="form-group">
                                                <label class="control-label required">Désignation</label>
                                            </div>
                                        </div>
                                        <div class="col-md-2">
                                            <div class="form-group">
                                                <label class="control-label required">Qte</label>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="ligneBonCommandeFrss" data-prototype="{{ _self.prototype_lignes(form.ligneBonCommandeFrss.vars.prototype)|e }}">
                                        {# iterate over each existing tag and render its only field: name #}
                                        {% for ligne in form.ligneBonCommandeFrss %}
                                            <script type="text/javascript">
                                                $arrayOfIndexes.push($cmp);
                                                $cmp++;
                                            </script>
                                            <div class="row ligne">
                                                <div class="col-md-4">
                                                    <div class="row">
                                                        <div class="col-xs-10"> 
                                                            {{ form_row(ligne.article,{'label':false,'required':false,'attr':{'autocomplete':'off','onchange':'changeArticle(this)'}}) }}
                                                        </div>
                                                        <div class="col-xs-1"> 
                                                            <a onclick="articleCustomNewFn(this);" title='Ajouter un article rapidement' class='btn btn-success' data-toggle='modal' data-target='#articleCustomNew'>
                                                                <span class='fa fa-plus'></span>
                                                            </a>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md-5">{{ form_row(ligne.designation,{'label':false,'required':false,'attr':{'style': 'height:34px!important'} } ) }}</div>
                                                <div class="col-md-2">{{ form_row(ligne.qte,{'label':false,'required':false,'attr':{'autocomplete':'off','onkeyup':'changeTTC(this)'}}) }}</div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>
                        </div>
                        {{ form_row(form.save) }}
                        {{ form_row(form.saveAndPrint) }}
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
{% block javascripts %}
    <script type="text/javascript">
        let articleCustomNew = null;
        let idArticleCustomNew = null;
        let arrayOfArticle = [];
        function articleCustomNewFn(btnArticleCustomNew) {
            let colMd2 = btnArticleCustomNew.closest('.col-md-4');
            articleCustomNew = jQuery(colMd2).find('select').prop('id');
            idArticleCustomNew = articleCustomNew.substring(46, articleCustomNew.lastIndexOf('_'));
        }
        //on submit article form
        //add article to this select
        // add article to all select
        jQuery('body').on('submit', '.articleForm', function (e) {
            e.preventDefault();
            jQuery.ajax({
                type: jQuery(this).attr('method'),
                url: jQuery(this).attr('action'),
                data: jQuery(this).serialize()
            }).done(function (data) {
                if (data.success) {
                    jQuery("#articleCustomNew .close").click();
                    jQuery("#articleForm")[0].reset();
                    //add article to this select
                    jQuery('#' + articleCustomNew).append('<option selected value=' + data.articleId + '>' + data.code + '</option>');
                    jQuery('#' + articleCustomNew).selectpicker('refresh');
                    arrayOfArticle.push(data.articleId);
                    arrayOfArticle.push(data.code);
                    jQuery('#appbundle_boncommandefrs_ligneBonCommandeFrss_' + idArticleCustomNew + '_designation').text(data.designation);
                    //document.getElementById('appbundle_boncommandefrs_ligneBonCommandeFrss_' + idArticleCustomNew + '_designation').value=data.designation;
                    // add article to all select
                    for (var i = 0; i < $arrayOfIndexes.length; i++) {
                        if (jQuery('#appbundle_boncommandefrs_ligneBonCommandeFrss_' + $arrayOfIndexes[i] + '_article')) {
                            jQuery('#appbundle_boncommandefrs_ligneBonCommandeFrss_' + $arrayOfIndexes[i] + '_article').append('<option value=' + data.articleId + '>' + data.code + '</option>');
                            jQuery('#appbundle_boncommandefrs_ligneBonCommandeFrss_' + $arrayOfIndexes[i] + '_article').selectpicker('refresh');
                        }
                    }
                } else {
                    jQuery('.articleForm').replaceWith(jQuery(data));
                    jQuery('#appbundle_article_fournisseur').selectpicker('refresh');
                }
            });
        });
        //on submit fournisseur form
        //add fournisseur to boncommandefrs
        jQuery('body').on('submit', '.fournisseurForm', function (e) {
            e.preventDefault();
            jQuery.ajax({
                type: jQuery(this).attr('method'),
                url: jQuery(this).attr('action'),
                data: jQuery(this).serialize()
            }).done(function (data) {
                if (data.success) {
                    jQuery("#fournisseurForm")[0].reset();
                    jQuery('#appbundle_boncommandefrs_fournisseur').append('<option selected value=' + data.fournisseurId + '>' + data.toString + '</option>');
                    jQuery('#appbundle_boncommandefrs_fournisseur').selectpicker('refresh');
                    jQuery('#appbundle_article_fournisseur').append('<option value=' + data.fournisseurId + '>' + data.toString + '</option>');
                    jQuery('#appbundle_article_fournisseur').selectpicker('refresh');
                    jQuery("#fournisseurCustomNew .close").click();
                } else {
                    jQuery('.fournisseurForm').replaceWith(jQuery(data));
                }
            });
        });
        function addLigneFormDeleteLink($ligneFormLi, index) {
            var $removeFormA = $('<div class="col-sm-1"><div class="form-group"><button type="button" id="delete_link" href="#" class="btn btn-danger"><span class="glyphicon glyphicon-minus"></span></button> </div></div>');
            $ligneFormLi.append($removeFormA);
            $removeFormA.on('click', function (e) {
                var i = Number(index) - 1;
                $arrayOfIndexes.splice($arrayOfIndexes.indexOf(i), 1);
                // prevent the link from creating a "#" on the URL
                e.preventDefault();
                // remove the li for the tag form
                $ligneFormLi.remove();
            });
        }
        function addLigneForm($collectionHolder, $newLinkLi) {
            if ($collectionHolder) {
                // Get the data-prototype explained earlier
                var prototype = $collectionHolder.data('prototype');
                // get the new index
                var index = $collectionHolder.data('index');
                $arrayOfIndexes.push(index);

                // Replace '__name__' in the prototype's HTML to
                // instead be a number based on how many items we have
                var newForm = prototype.replace(/__name__/g, index);
                // increase the index with one for the next item
                $collectionHolder.data('index', index + 1);
                // Display the form in the page in an li, before the "Add a tag" link li
                var $newFormLi = $('<div class="row"></div>').append(newForm);
                $newLinkLi.before($newFormLi);
                addLigneFormDeleteLink($newFormLi, $collectionHolder.data('index'));
                for (var i = 0; i < arrayOfArticle.length; i += 2) {
                    jQuery('#appbundle_boncommandefrs_ligneBonCommandeFrss_' + index + '_article').append('<option value=' + arrayOfArticle[i] + '>' + arrayOfArticle[i + 1] + '</option>');
                }
                jQuery('#appbundle_boncommandefrs_ligneBonCommandeFrss_' + index + '_article').selectpicker('refresh');
            }
        }
        var $collectionHolder;
// setup an "add a tag" link
        var $addLigneLink = $('');
        var $newLinkLi = $('<div></div>').append($addLigneLink);
        $(document).ready(function () {
            // Get the ul that holds the collection of tags
            $collectionHolder = $('div.ligneBonCommandeFrss');
            // add a delete link to all of the existing tag form li elements
            $collectionHolder.find('div.row.ligne').each(function () {
                addLigneFormDeleteLink($(this), $collectionHolder.data('index'));
            });
            // add the "add a tag" anchor and li to the tags ul
            $collectionHolder.append($newLinkLi);
            // count the current form inputs we have (e.g. 2), use that as the new
            // index when inserting a new item (e.g. 2)
            $collectionHolder.data('index', $collectionHolder.find(':input').length);
            $addLigneLink.on('click', function (e) {
                // prevent the link from creating a "#" on the URL
                e.preventDefault();
                // add a new tag form (see next code block)
                addLigneForm($collectionHolder, $newLinkLi);
            });
        });
        function changeArticleFN(selectedOption, index) {
            jQuery.ajax({
                method: "GET",
                url: "{{ path('article') }}",
                data: {
                    id: selectedOption
                }
            }).done(function (data) {
                var obj = jQuery.parseJSON(JSON.stringify(data));
                if (obj.success === true) {
                    if (obj.article) {
                        var article = jQuery.parseJSON(obj.article);
                        if (article.designation) {
                            document.getElementById('appbundle_boncommandefrs_ligneBonCommandeFrss_' + index + '_designation').value = article.designation;
                        } else {
                            document.getElementById('appbundle_boncommandefrs_ligneBonCommandeFrss_' + index + '_designation').value = article.code;
                        }
                    }
                }
            });
        }
        function changeArticle(select) {
            var selectedOption = select.options[select.selectedIndex].value;
            var index = select.id.substring(46, select.id.lastIndexOf('_'));
            changeArticleFN(selectedOption, index);
        }
        Array.prototype.inArray = function (value) {
            // Returns true if the passed value is found in the
            // array. Returns false if it is not.
            var i;
            for (i = 0; i < this.length; i++) {
                if (this[i] === value) {
                    return true;
                }
            }
            return false;
        };

        setInterval(function () {
            if ($arrayOfIndexes && $arrayOfIndexes.length > 0) {
                if (document.getElementById('appbundle_boncommandefrs_ligneBonCommandeFrss_' + $arrayOfIndexes[$arrayOfIndexes.length - 1] + '_article')) {
                    var lastArticle = document.getElementById('appbundle_boncommandefrs_ligneBonCommandeFrss_' + $arrayOfIndexes[$arrayOfIndexes.length - 1] + '_article').value;
                    if (lastArticle !== '') {
                        addLigneForm($collectionHolder, $newLinkLi);
                    }
                }
            } else {
                addLigneForm($collectionHolder, $newLinkLi);
            }
        }, 0.00001);
    </script>
{% endblock %}
