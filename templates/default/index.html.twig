{% endblock %}
{% block javascripts %}
    <script type="text/javascript">
        $(function () {
            $('#datetimepicker12').datepicker({
                inline: true,
                sideBySide: true,
                language: "{{ app.request.locale }}",
                todayHighlight: true
            });
        });
    </script>
{% endblock %}
