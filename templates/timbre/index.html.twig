{% extends 'base.html.twig' %}
{% block title %}{{ parent()~' - Timbre fiscal' }}{% endblock %}
{% block body %}
    <div class="container-fluid container-fluid-fixed-top">
        <div class="row">
            <div class="col-lg-6 col-lg-offset-3">
                <div class="panel panel-default">
                    <div class="panel-heading">
                        Timbre fiscal
                    </div>
                    <div class="panel-body">
                        <p class="text-muted">
                            Valeur du droit de timbre appliquée aux nouvelles factures et avoirs.
                            La modification n'affecte pas les documents déjà enregistrés.
                        </p>
                        {% form_theme form 'bootstrap_3_layout.html.twig' %}
                        {{ form_start(form) }}
                        {{ form_widget(form) }}
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
