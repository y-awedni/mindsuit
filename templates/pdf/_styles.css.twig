body { font-family: sans-serif; font-size: 11px; color: #333; }
.doc-title { font-size: 20px; font-weight: bold; }
table { width: 100%; border-collapse: collapse; }
td { vertical-align: top; }
.header td { padding: 0; }

/* parties row: societe info on the LEFT, client box on the RIGHT */
.parties { margin-top: 8px; }
.parties .societe-col { width: 55%; padding: 4px 12px 4px 0; }
.parties .client-col { width: 45%; padding: 4px 0; }

/* client box: nested table with header row (the cyan stripe) and content row */
.client-box { border: 1px solid #555; line-height: 1.55; }
.client-box th {
    background: #f0f0f0;
    border-bottom: 1px solid #555;
    padding: 5px 8px;
    text-align: left;
    font-weight: bold;
    font-size: 12px;
}
.client-box td { padding: 6px 8px; font-size: 11px; }

.lines { margin-top: 10px; }
.lines th { background: #13b3d9; color: #fff; border: 1px solid #ddd; padding: 4px; font-size: 11px; }
.lines td { border: 1px solid #eee; padding: 4px; }
.lines tr:nth-child(even) td { background: #f6f6f6; }
.center { text-align: center; }
.right { text-align: right; }
.totaux table, .tva table { border: 1px solid #ddd; }
.totaux th, .totaux td, .tva th, .tva td { border: 1px solid #ddd; padding: 4px; }
.tva th { background: #13b3d9; color: #fff; }
.totaux th { background: #eee; text-align: left; width: 55%; }
.summary td { width: 50%; vertical-align: bottom; }
.lettres { font-size: 11px; }
.signatures { margin-top: 14px; }
.signatures td { border: 1px solid #999; height: 60px; width: 33%; padding: 4px; font-size: 10px; }
