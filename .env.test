# Test environment defaults. The control DB holds the tenant registry; the
# smoke test resolves the "minduos" tenant (existing data) on bare localhost.
# NOTE: .env.local is NOT loaded in the test env, so set the control DB here.
APP_ENV=test
APP_DEBUG=1
DATABASE_URL="mysql://mindsuit:mindsuit@database:3306/moudir_master?serverVersion=5.7"
APP_BASE_DOMAIN=localhost
DEFAULT_TENANT=minduos
